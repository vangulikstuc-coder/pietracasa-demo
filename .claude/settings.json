{
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Read",
      "Write",
      "Edit",
      "MultiEdit"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(rm -rf*)",
      "Bash(wrangler deploy*)",
      "Bash(vercel --prod*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[v3.0 guard] Check: $(pwd)\""
          }
        ]
      }
    ]
  }
}