---
import { Picture, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroGevelwerk from '../assets/images/hero/hero-gevelwerk.jpg';
import dienstGevelwerk from '../assets/images/sections/dienst-gevelwerk.jpg';
import galerijGevelVoor from '../assets/images/sections/galerij-gevel-voor.jpg';
import galerijGevelNa from '../assets/images/sections/galerij-gevel-na.jpg';
import droneGevelwerk from '../assets/images/sections/drone-gevelwerk.jpg';
import ctaSfeer from '../assets/images/sections/cta-sfeer.jpg';

const heroWidths = [768, 1280, 1920];
const heroSizes = '100vw';
const heroAvif = await Promise.all(
  heroWidths.map(async (width) => ({
    width,
    image: await getImage({ src: heroGevelwerk, width, format: 'avif' }),
  }))
);
const heroPreloadSrcset = heroAvif.map(({ width, image }) => `${image.src} ${width}w`).join(', ');

const ogImage = await getImage({ src: heroGevelwerk, width: 1200, format: 'jpg' });

const cardWidths = [420, 840];
const cardSizes = '(min-width: 900px) 45vw, 100vw';

const werkzaamheden = [
  {
    titel: 'Gevelstuc aanbrengen',
    tekst: 'Nieuw buitenstucwerk op de gevel, egaal en strak afgewerkt.',
  },
  {
    titel: 'Herstel en gevelrenovatie',
    tekst: 'Scheuren, gaten en verweerd stucwerk hersteld vóór de nieuwe afwerklaag.',
  },
  {
    titel: 'Buitenafwerking',
    tekst: 'Strakke detaillering rond kozijnen en plinten – schilderklaar opgeleverd.',
  },
];

const stappen = [
  {
    nr: '01',
    titel: 'Inspectie op locatie',
    tekst: 'Wij bekijken de gevel ter plaatse en bespreken de gewenste afwerking.',
    icon: 'pin',
  },
  {
    nr: '02',
    titel: 'Vaste prijs op schrift',
    tekst: 'Na de inspectie ontvangt u een offerte met vaste prijs en planning.',
    icon: 'document',
  },
  {
    nr: '03',
    titel: 'Uitvoering volgens planning',
    tekst: 'Meerwerk alleen na uw schriftelijk akkoord. De opleveringsafspraak staat op papier.',
    icon: 'roller',
  },
];

const starPath =
  'M12 2.8l2.85 5.78 6.38.93-4.62 4.5 1.09 6.36L12 17.37l-5.7 3 1.09-6.36-4.62-4.5 6.38-.93L12 2.8z';

const icons: Record<string, string> = {
  star: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="${starPath}"/></svg>`,
  check:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 12.5l5 5 10-11"/></svg>',
  pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>',
  document:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>',
  roller:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="13" height="6" rx="2"/><path d="M16 6h4v4h-8v4"/><path d="M12 14v6"/></svg>',
  shield:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="m9 11.5 2 2 4-4"/></svg>',
};

const feiten = [
  { icon: 'star', tekst: '4,8 sterren op Google – 25+ geverifieerde reviews' },
  { icon: 'check', tekst: '50+ projecten sinds 2020, op tijd en in budget' },
  { icon: 'shield', tekst: 'KvK-geregistreerd en verzekerd' },
];
---

<BaseLayout
  title="Gevelwerk in Haarlem | Stucq"
  description="Gevelwerk en buitenafwerking in Haarlem op vaste prijs. Bekijk voor-na resultaten van afgeronde gevelprojecten en vraag vrijblijvend een offerte aan."
  ogImage={ogImage.src}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    type="image/avif"
    imagesrcset={heroPreloadSrcset}
    imagesizes={heroSizes}
  />

  <!-- 1. Pagina-hero -->
  <section class="page-hero" aria-labelledby="gevelwerk-title">
    <div class="page-hero__bg" aria-hidden="true">
      <Picture
        src={heroGevelwerk}
        widths={heroWidths}
        sizes={heroSizes}
        formats={['avif', 'webp']}
        alt=""
        fetchpriority="high"
        loading="eager"
        data-demo="true"
      />
    </div>
    <div class="container page-hero__inner">
      <p class="eyebrow eyebrow--inverse">Gevelwerk &amp; buitenafwerking</p>
      <h1 id="gevelwerk-title">Gevelwerk in Haarlem – vaste prijs, op tijd opgeleverd</h1>
      <p class="page-hero__sub">
        Stucq herstelt en stuukt buitengevels in Haarlem en omgeving. U ontvangt vooraf een vaste
        prijs op schrift – en Stucq houdt zich daaraan.
      </p>
      <div class="page-hero__actions">
        <a href="/offerte/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="tel:0681943404" class="page-hero__tel">Bel voor advies: 06 81 94 34 04</a>
      </div>
      <p class="page-hero__micro">Vrijblijvend – vaste prijs, reactie binnen 48 uur.</p>
    </div>
  </section>

  <!-- 2. Kern-inhoud: wat valt onder gevelwerk -->
  <section class="section" aria-labelledby="dienst-title">
    <div class="container dienst" data-reveal-group>
      <div class="dienst__text">
        <p class="eyebrow">De dienst</p>
        <h2 id="dienst-title">Wat valt onder gevelwerk</h2>
        <p class="dienst__intro">
          Eén vakman verzorgt het complete buitenstucwerk – van inspectie tot oplevering. Voor
          bouwbedrijven, vastgoedprojecten en particuliere woningen.
        </p>
        <ol class="werklijst" role="list">
          {
            werkzaamheden.map((werk, i) => (
              <li class="werklijst__item">
                <span class="werklijst__nr tabular" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div>
                  <h3>{werk.titel}</h3>
                  <p>{werk.tekst}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
      <figure class="dienst__media">
        <Picture
          src={dienstGevelwerk}
          widths={cardWidths}
          sizes={cardSizes}
          formats={['avif', 'webp']}
          alt="Vakman stukadoort een gevel vanaf een steiger in Haarlem"
          loading="lazy"
          decoding="async"
          data-demo="true"
        />
      </figure>
    </div>
  </section>

  <!-- 2b. Kern-inhoud: zo komt de vaste prijs tot stand (prijsafspraak, niet het 5-stappen-proces) -->
  <section class="section section--alt" aria-labelledby="prijs-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Vaste prijs</p>
        <h2 id="prijs-title">Vóór de start op papier</h2>
        <p class="section-head__intro">
          Geen open eindjes bij gevelwerk. U weet vooraf wat het kost en wanneer de steiger weer
          weg is.
        </p>
      </header>
      <ol class="stappen" role="list" data-reveal-group>
        {
          stappen.map((stap) => (
            <li class="stap">
              <div class="stap__top">
                <span class="stap__icon" set:html={icons[stap.icon]} aria-hidden="true" />
                <span class="stap__nr tabular" aria-hidden="true">
                  {stap.nr}
                </span>
              </div>
              <h3>{stap.titel}</h3>
              <p>{stap.tekst}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- 3. Bewijs: voor-na + feiten + drone-still -->
  <section class="section" aria-labelledby="bewijs-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Bewijs</p>
        <h2 id="bewijs-title">Het verschil bij gevelwerk – voor en na</h2>
        <p class="section-head__intro">
          Bekijk een afgerond gevelproject uit Haarlem. Wissel tussen de voor- en na-foto.
        </p>
      </header>
      <div class="bewijs" data-reveal-group>
        <figure class="ba-card" data-ba>
          <div class="ba-card__media">
            <div class="ba-card__panel is-active" data-ba-panel="na">
              <Picture
                src={galerijGevelNa}
                widths={cardWidths}
                sizes={cardSizes}
                formats={['avif', 'webp']}
                alt="Na: strak gestuukte, egaal afgewerkte gevel"
                loading="lazy"
                decoding="async"
                data-demo="true"
              />
            </div>
            <div class="ba-card__panel" data-ba-panel="voor" aria-hidden="true">
              <Picture
                src={galerijGevelVoor}
                widths={cardWidths}
                sizes={cardSizes}
                formats={['avif', 'webp']}
                alt="Voor: gevel met gescheurd en verweerd stucwerk"
                loading="lazy"
                decoding="async"
                data-demo="true"
              />
            </div>
          </div>
          <div class="ba-card__bar">
            <figcaption>Gevelwerk · Haarlem</figcaption>
            <div class="ba-toggle" role="group" aria-label="Voor- of na-foto tonen">
              <button type="button" data-ba-show="voor" aria-pressed="false">Voor</button>
              <button type="button" data-ba-show="na" aria-pressed="true">Na</button>
            </div>
          </div>
        </figure>
        <div class="bewijs__text">
          <p>
            Elk gevelproject sinds 2020 is binnen budget en op de afgesproken datum opgeleverd.
            Niet als belofte, maar als trackrecord.
          </p>
          <ul class="bewijs__feiten" role="list">
            {
              feiten.map((feit) => (
                <li>
                  <span class="bewijs__icon" set:html={icons[feit.icon]} aria-hidden="true" />
                  {feit.tekst}
                </li>
              ))
            }
          </ul>
          <a href="/projecten/" class="btn btn--secondary">Bekijk alle afgeronde projecten</a>
        </div>
      </div>
      <figure class="drone" data-reveal>
        <Picture
          src={droneGevelwerk}
          widths={[768, 1280, 1920]}
          sizes="(min-width: 1280px) 1216px, 100vw"
          formats={['avif', 'webp']}
          alt="Drone-opname van een gevelproject in de regio Haarlem, van fundering tot nok"
          loading="lazy"
          decoding="async"
          data-demo="true"
        />
        <figcaption class="drone__chip">
          Still uit drone-opname · gevelwerk van fundering tot nok
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- 4. CTA-band -->
  <section class="cta-band" aria-labelledby="cta-title">
    <div class="cta-band__bg" aria-hidden="true">
      <Picture
        src={ctaSfeer}
        widths={[820, 1280, 1920]}
        sizes="100vw"
        formats={['avif', 'webp']}
        alt=""
        loading="lazy"
        decoding="async"
        data-demo="true"
      />
    </div>
    <div class="container cta-band__inner" data-reveal>
      <h2 id="cta-title">Gevelwerk gepland in Haarlem of omgeving?</h2>
      <p class="cta-band__sub">
        Vraag een vrijblijvende offerte aan – vaste prijs, reactie binnen 48 uur.
      </p>
      <div class="cta-band__actions">
        <a href="/offerte/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="tel:0681943404" class="cta-band__tel">Bel direct: 06 81 94 34 04</a>
      </div>
      <p class="cta-band__micro">
        Vrijblijvend – vaste prijs, reactie binnen 48 uur. Bereikbaar ma–vr 7:00–17:00.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Gedeelde sectie-koppen --- */
  .eyebrow {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .eyebrow--inverse {
    color: var(--color-neutral-100);
  }

  .section-head {
    max-width: 68ch;
    margin-block-end: clamp(var(--spacing-xl), 6vw, var(--spacing-2xl));
  }

  .section-head h2 {
    margin-block-start: var(--spacing-md);
  }

  .section-head__intro {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
  }

  /* --- 1. Pagina-hero --- */
  .page-hero {
    position: relative;
    overflow: hidden;
    display: grid;
    align-items: end;
    min-height: clamp(440px, 60vh, 620px);
    padding-block: clamp(var(--spacing-2xl), 9vw, var(--spacing-section));
    color: var(--color-text-inverse);
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
  }

  .page-hero__bg :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .page-hero__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: hero-settle 1200ms cubic-bezier(0.22, 1, 0.36, 1) 250ms both;
  }

  /* Signature: gladstrijkende laag trekt van links naar rechts over het beeld */
  .page-hero__bg::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(100deg, var(--color-neutral-100), var(--color-neutral-300));
    transform-origin: right center;
    animation: hero-sweep 1000ms cubic-bezier(0.22, 1, 0.36, 1) 250ms both;
  }

  /* AA-contrast op licht beeld: mobiel beslaat de tekst bijna de hele hero (vlakkere scrim);
     desktop staat de tekst linksonder — daar extra dekking, rechtsboven blijft het beeld vrij */
  .page-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-neutral-900) 92%, transparent),
      color-mix(in srgb, var(--color-neutral-900) 78%, transparent) 50%,
      color-mix(in srgb, var(--color-neutral-900) 66%, transparent)
    );
  }

  @media (min-width: 768px) {
    .page-hero__bg::after {
      background:
        linear-gradient(
          to right,
          color-mix(in srgb, var(--color-neutral-900) 60%, transparent),
          color-mix(in srgb, var(--color-neutral-900) 32%, transparent) 45%,
          transparent 72%
        ),
        linear-gradient(
          to top,
          color-mix(in srgb, var(--color-neutral-900) 92%, transparent),
          color-mix(in srgb, var(--color-neutral-900) 74%, transparent) 42%,
          color-mix(in srgb, var(--color-neutral-900) 40%, transparent) 75%,
          color-mix(in srgb, var(--color-neutral-900) 18%, transparent)
        );
    }
  }

  @keyframes hero-sweep {
    from {
      transform: scaleX(1);
    }
    to {
      transform: scaleX(0);
    }
  }

  @keyframes hero-settle {
    from {
      transform: scale(1.06);
    }
    to {
      transform: scale(1);
    }
  }

  .page-hero__inner {
    position: relative;
    z-index: 3;
  }

  .page-hero h1 {
    margin-block-start: var(--spacing-md);
    max-width: 22ch;
  }

  .page-hero__sub {
    margin-block-start: var(--spacing-md);
    font-size: clamp(var(--font-size-base), 2.5vw, var(--font-size-md));
    color: var(--color-neutral-100);
    max-width: 54ch;
  }

  .page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md) var(--spacing-lg);
    margin-block-start: var(--spacing-xl);
  }

  .page-hero__actions .btn {
    width: 100%;
  }

  @media (min-width: 640px) {
    .page-hero__actions .btn {
      width: auto;
    }
  }

  .page-hero__tel {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-text-inverse);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .page-hero__tel:hover {
    color: var(--color-neutral-200);
  }

  .page-hero__micro {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--color-neutral-300);
  }

  /* --- 2. Dienst-blok --- */
  .dienst {
    display: grid;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .dienst__text h2 {
    margin-block-start: var(--spacing-md);
  }

  .dienst__intro {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
    max-width: 54ch;
  }

  .werklijst {
    list-style: none;
    margin: var(--spacing-xl) 0 0;
    padding: 0;
  }

  .werklijst__item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    padding-block: var(--spacing-md);
    border-top: 1px solid var(--color-border-default);
  }

  .werklijst__item:last-child {
    border-bottom: 1px solid var(--color-border-default);
  }

  .werklijst__nr {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
    font-family: var(--font-display);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-sm);
  }

  .werklijst__item h3 {
    font-size: var(--font-size-base);
  }

  .werklijst__item p {
    margin-block-start: var(--spacing-xs);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    max-width: 48ch;
  }

  .dienst__media {
    margin: 0;
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .dienst__media :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .dienst__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 900px) {
    .dienst {
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--spacing-2xl);
    }
  }

  /* --- 2b. Stappen --- */
  .stappen {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--spacing-lg);
  }

  .stap {
    background: var(--color-surface-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: var(--spacing-lg);
  }

  .stap__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
  }

  .stap__icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
  }

  .stap__icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .stap__nr {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-300);
  }

  .stap h3 {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-md);
  }

  .stap p {
    margin-block-start: var(--spacing-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  @media (min-width: 768px) {
    .stappen {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* --- 3. Bewijs --- */
  .bewijs {
    display: grid;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .ba-card {
    margin: 0;
    background: var(--color-surface-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .ba-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
  }

  .ba-card__panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--motion-base) var(--motion-easing);
  }

  .ba-card__panel.is-active {
    opacity: 1;
  }

  .ba-card__panel :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .ba-card__panel :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-card__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .ba-card__bar figcaption {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
  }

  .ba-toggle {
    display: inline-flex;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-pill);
    padding: var(--spacing-xs);
    gap: var(--spacing-xs);
  }

  .ba-toggle button {
    min-height: 36px;
    min-width: 56px;
