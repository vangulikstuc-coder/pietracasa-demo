---
import { Picture, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroHome from '../assets/images/hero/hero-home.jpg';
import dienstGevelwerk from '../assets/images/sections/dienst-gevelwerk.jpg';
import dienstBinnenafwerking from '../assets/images/sections/dienst-binnenafwerking.jpg';
import dienstMicrocement from '../assets/images/sections/dienst-microcement.jpg';
import galerijGevelVoor from '../assets/images/sections/galerij-gevel-voor.jpg';
import galerijGevelNa from '../assets/images/sections/galerij-gevel-na.jpg';
import galerijBinnenVoor from '../assets/images/sections/galerij-binnen-voor.jpg';
import galerijBinnenNa from '../assets/images/sections/galerij-binnen-na.jpg';
import galerijVloerVoor from '../assets/images/sections/galerij-vloer-voor.jpg';
import galerijVloerNa from '../assets/images/sections/galerij-vloer-na.jpg';
import ctaSfeer from '../assets/images/sections/cta-sfeer.jpg';

/* Hero als 50/50-split uit de losse voor/na-helften: de deellijn ligt daardoor
   op elk breakpoint exact op het midden (composiet hero-home.jpg is alleen nog OG-beeld) */
const heroHalfWidths = [320, 640, 960, 1248];
const heroHalfSizes = '(min-width: 1024px) 25vw, 50vw';
const heroPreloadSrcsets = await Promise.all(
  [galerijGevelVoor, galerijGevelNa].map(async (src) => {
    const images = await Promise.all(
      heroHalfWidths.map(async (width) => ({
        width,
        image: await getImage({ src, width, format: 'avif' }),
      }))
    );
    return images.map(({ width, image }) => `${image.src} ${width}w`).join(', ');
  })
);

const ogImage = await getImage({ src: heroHome, width: 1200, format: 'jpg' });

const cardWidths = [420, 840];
const cardSizes = '(min-width: 768px) 30vw, 100vw';

const diensten = [
  {
    href: '/diensten/gevelwerk-buitenafwerking/',
    titel: 'Gevelwerk & buitenafwerking',
    belofte: 'Strakke gevels op vaste prijs, binnen de afgesproken bouwtermijn.',
    src: dienstGevelwerk,
    alt: 'Vakman stukadoort een gevel vanaf een steiger',
    foto: 'gevelwerk',
  },
  {
    href: '/diensten/binnenafwerking-renovatie/',
    titel: 'Binnenafwerking & renovatie',
    belofte: 'Wanden en plafonds strak opgeleverd – klaar voor verf of behang.',
    src: dienstBinnenafwerking,
    alt: 'Vakman pleistert een binnenwand',
    foto: 'binnen',
  },
  {
    href: '/diensten/microcement-vloeren/',
    titel: 'Microcement vloeren',
    belofte: 'Naadloze vloeren met een vaste prijsopgave vooraf.',
    src: dienstMicrocement,
    alt: 'Vakman brengt microcement aan op een vloer',
    foto: 'vloer',
  },
];

const galerij = [
  {
    id: 'gevel',
    label: 'Gevelwerk · Haarlem',
    voor: { src: galerijGevelVoor, alt: 'Voor: gevel met gescheurd en verweerd stucwerk' },
    na: { src: galerijGevelNa, alt: 'Na: strak gestuukte, egaal afgewerkte gevel' },
  },
  {
    id: 'binnen',
    label: 'Binnenafwerking · regio Haarlem',
    voor: { src: galerijBinnenVoor, alt: 'Voor: woonkamer met beschadigde wanden' },
    na: { src: galerijBinnenNa, alt: 'Na: woonkamer met strak gepleisterde wanden' },
  },
  {
    id: 'vloer',
    label: 'Microcement vloer · Haarlem',
    voor: { src: galerijVloerVoor, alt: 'Voor: verouderde vloer voor de renovatie' },
    na: { src: galerijVloerNa, alt: 'Na: naadloze microcement vloer' },
  },
];

const stappen = [
  {
    nr: '01',
    titel: 'Opname op locatie',
    tekst:
      'U vraagt een offerte aan via het formulier of telefonisch. Binnen 48 uur plannen wij een opname op locatie.',
    icon: 'pin',
  },
  {
    nr: '02',
    titel: 'Offerte met vaste prijs',
    tekst: 'Na de opname ontvangt u een schriftelijke offerte: vaste prijs en heldere werkomschrijving.',
    icon: 'document',
  },
  {
    nr: '03',
    titel: 'Planning op papier',
    tekst: 'Start- en opleverdatum staan vóór de start zwart op wit. U weet wanneer het werk klaar is.',
    icon: 'calendar',
  },
  {
    nr: '04',
    titel: 'Uitvoering volgens planning',
    tekst: 'Eén vakman is uw aanspreekpunt. Meerwerk gebeurt alleen na uw schriftelijk akkoord.',
    icon: 'roller',
  },
  {
    nr: '05',
    titel: 'Oplevering',
    tekst: 'U loopt het werk samen met de vakman na. Oplevering op de afgesproken datum, binnen de vaste prijs.',
    icon: 'badge',
  },
];

const garanties = [
  {
    titel: 'Vaste prijsgarantie',
    tekst: 'De offerteprijs is de eindprijs. Meerwerk alleen na uw schriftelijk akkoord.',
    icon: 'euro',
  },
  {
    titel: 'Op tijd opgeleverd',
    tekst: '50+ projecten sinds 2020, allemaal binnen de afgesproken planning.',
    icon: 'clock',
  },
  {
    titel: 'Schriftelijke afspraken',
    tekst: 'Prijs, planning en oplevering staan vóór de start op papier.',
    icon: 'contract',
  },
  {
    titel: 'KvK-geregistreerd & verzekerd',
    tekst: 'Voor zowel particulier als zakelijk werk in de regio Haarlem.',
    icon: 'shield',
  },
];

const problemen = [
  'Onduidelijke kosten – de eindprijs blijkt hoger dan de offerte.',
  'Uitloop – de planning schuift zonder overleg.',
  'Niets op papier – afspraken zijn achteraf niet te controleren.',
];

const oplossingen = [
  'Schriftelijke vaste prijs vóór de start. Meerwerk alleen na uw akkoord.',
  'Planning vooraf vastgelegd. 50+ projecten sinds 2020 op tijd opgeleverd.',
  'Elke afspraak op papier, van offerte tot oplevering. Reactie binnen 48 uur.',
];

const starPath =
  'M12 2.8l2.85 5.78 6.38.93-4.62 4.5 1.09 6.36L12 17.37l-5.7 3 1.09-6.36-4.62-4.5 6.38-.93L12 2.8z';

const icons: Record<string, string> = {
  star: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="${starPath}"/></svg>`,
  starPartial: `<svg viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="star-partial-grad"><stop offset="0.8" stop-color="currentColor"/><stop offset="0.8" stop-color="transparent"/></linearGradient></defs><path d="${starPath}" fill="url(#star-partial-grad)" stroke="currentColor" stroke-width="1"/></svg>`,
  check:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 12.5l5 5 10-11"/></svg>',
  x: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>',
  phone:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>',
  calendar:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/><path d="m9.5 15.5 2 2 3.5-4"/></svg>',
  document:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>',
  roller:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="13" height="6" rx="2"/><path d="M16 6h4v4h-8v4"/><path d="M12 14v6"/></svg>',
  badge:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="9" r="6"/><path d="m9.5 9 1.8 1.8L15 7.2"/><path d="M8.5 13.5 7 22l5-3 5 3-1.5-8.5"/></svg>',
  euro: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.5 7a6.5 6.5 0 1 0 0 10"/><path d="M5 10.5h8M5 13.5h8"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg>',
  contract:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg>',
  shield:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="m9 11.5 2 2 4-4"/></svg>',
};
---

<BaseLayout
  title="Stucadoor in Haarlem | Stucq"
  description="Stucadoor in Haarlem voor gevelwerk, binnenafwerking en microcement. Vaste prijs, 50+ projecten op tijd opgeleverd. Vraag vrijblijvend een offerte aan."
  ogImage={ogImage.src}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    type="image/avif"
    imagesrcset={heroPreloadSrcsets[0]}
    imagesizes={heroHalfSizes}
  />
  <link
    slot="head"
    rel="preload"
    as="image"
    type="image/avif"
    imagesrcset={heroPreloadSrcsets[1]}
    imagesizes={heroHalfSizes}
  />

  <!-- 1. Hero -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="container hero__grid">
      <div class="hero__media">
        <div class="hero__split">
          <Picture
            src={galerijGevelVoor}
            widths={heroHalfWidths}
            sizes={heroHalfSizes}
            formats={['avif', 'webp']}
            alt="Vóór: gevel met gescheurd en afgebladderd stucwerk in Haarlem"
            fetchpriority="high"
            loading="eager"
            data-demo="true"
          />
          <Picture
            src={galerijGevelNa}
            widths={heroHalfWidths}
            sizes={heroHalfSizes}
            formats={['avif', 'webp']}
            alt="Na: dezelfde gevel strak gestuukt en geschilderd"
            fetchpriority="high"
            loading="eager"
            data-demo="true"
          />
        </div>
        <p class="hero__chip">Voor en na · gevelproject Haarlem</p>
      </div>
      <div class="hero__content" data-reveal>
        <p class="eyebrow">Gevelwerk · Binnenafwerking · Microcement vloeren</p>
        <h1 id="hero-title">Stucadoor in Haarlem – vaste prijs, aantoonbaar op tijd</h1>
        <p class="hero__sub">
          U weet vooraf wat het kost – en Stucq houdt zich daaraan. 50+ projecten in Haarlem en
          omgeving sinds 2020, allemaal binnen budget en planning opgeleverd.
        </p>
        <ul class="hero__proof" role="list">
          <li>
            <span class="hero__proof-star" set:html={icons.star} aria-hidden="true" />
            4,8 op Google
          </li>
          <li>25+ geverifieerde reviews</li>
          <li>50+ projecten sinds 2020</li>
        </ul>
        <div class="hero__actions">
          <a href="/offerte-aanvragen/" class="btn btn--primary">
            Offerte aanvragen
            <span class="btn__arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href="/projecten/" class="btn btn--secondary">Bekijk afgeronde projecten</a>
        </div>
        <p class="micro">Vrijblijvend – vaste prijs, reactie binnen 48 uur.</p>
      </div>
    </div>
  </section>

  <!-- 2. Bewijs-band -->
  <section class="stats-band" aria-labelledby="stats-title">
    <div class="container">
      <h2 class="visually-hidden" id="stats-title">Bewijs in cijfers</h2>
      <dl class="stats" data-reveal-group>
        <div class="stats__item">
          <dt>Sterren op Google</dt>
          <dd>
            <span class="stats__num tabular" data-count-to="4.8" data-count-decimals="1">4,8</span>
            <span class="stats__star" set:html={icons.star} aria-hidden="true" />
          </dd>
        </div>
        <div class="stats__item">
          <dt>Geverifieerde reviews</dt>
          <dd><span class="stats__num tabular" data-count-to="25" data-count-suffix="+">25+</span></dd>
        </div>
        <div class="stats__item">
          <dt>Projecten sinds 2020</dt>
          <dd><span class="stats__num tabular" data-count-to="50" data-count-suffix="+">50+</span></dd>
        </div>
      </dl>
      <p class="stats__caption" data-reveal>
        Beoordeeld door bouwbedrijven en huiseigenaren in de regio Haarlem. Alle projecten op tijd
        en in budget afgeleverd.
      </p>
    </div>
  </section>

  <!-- 3. Probleem naar oplossing -->
  <section class="section section--alt" aria-labelledby="contrast-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Probleem en oplossing</p>
        <h2 id="contrast-title">Geen onduidelijke kosten. Geen uitloop.</h2>
        <p class="section-head__intro">
          Onduidelijke kosten en uitloop zijn de twee redenen waarom opdrachtgevers afhaken. Stucq
          werkt daarom uitsluitend op vaste prijs en legt elke afspraak schriftelijk vast.
        </p>
      </header>
      <div class="contrast" data-reveal-group>
        <div class="contrast__col">
          <h3>Waar opdrachtgevers op afhaken</h3>
          <ul role="list">
            {
              problemen.map((tekst) => (
                <li>
                  <span class="mark mark--x" set:html={icons.x} aria-hidden="true" />
                  {tekst}
                </li>
              ))
            }
          </ul>
        </div>
        <div class="contrast__col contrast__col--oplossing">
          <h3>Zo lost Stucq dat op</h3>
          <ul role="list">
            {
              oplossingen.map((tekst) => (
                <li>
                  <span class="mark mark--check" set:html={icons.check} aria-hidden="true" />
                  {tekst}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Diensten -->
  <section class="section" aria-labelledby="diensten-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Diensten</p>
        <h2 id="diensten-title">Drie diensten, elk met een vaste prijs</h2>
        <p class="section-head__intro">
          Gevelwerk, binnenafwerking en microcement vloeren – elk uitgevoerd op vaste prijs en
          binnen de afgesproken bouwtermijn. Vraag per dienst een aparte offerte aan.
        </p>
      </header>
      <div class="diensten" data-reveal-group>
        {
          diensten.map((dienst) => (
            <a href={dienst.href} class="dienst-card">
              <div class={`dienst-card__media dienst-card__media--${dienst.foto}`}>
                <Picture
                  src={dienst.src}
                  widths={cardWidths}
                  sizes={cardSizes}
                  formats={['avif', 'webp']}
                  alt={dienst.alt}
                  loading="lazy"
                  decoding="async"
                  data-demo="true"
                />
              </div>
              <div class="dienst-card__body">
                <h3>{dienst.titel}</h3>
                <p>{dienst.belofte}</p>
                <span class="dienst-card__more">
                  Meer informatie
                  <span class="dienst-card__arrow" aria-hidden="true">&rarr;</span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5. Projectbewijs / voor-na galerij -->
  <section class="section section--alt" aria-labelledby="galerij-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Projectbewijs</p>
        <h2 id="galerij-title">Het werk, voor en na</h2>
        <p class="section-head__intro">
          Bekijk afgeronde projecten in Haarlem, Bloemendaal en Zandvoort. Voor-na foto's van elk
          type werk dat Stucq uitvoert.
        </p>
      </header>
      <div class="galerij" data-reveal-group>
        {
          galerij.map((project) => (
            <figure class="ba-card" data-ba>
              <div class="ba-card__media">
                <div class="ba-card__panel is-active" data-ba-panel="na">
                  <Picture
                    src={project.na.src}
                    widths={cardWidths}
                    sizes={cardSizes}
                    formats={['avif', 'webp']}
                    alt={project.na.alt}
                    loading="lazy"
                    decoding="async"
                    data-demo="true"
                  />
                </div>
                <div class="ba-card__panel" data-ba-panel="voor" aria-hidden="true">
                  <Picture
                    src={project.voor.src}
                    widths={cardWidths}
                    sizes={cardSizes}
                    formats={['avif', 'webp']}
                    alt={project.voor.alt}
                    loading="lazy"
                    decoding="async"
                    data-demo="true"
                  />
                </div>
              </div>
              <div class="ba-card__bar">
                <figcaption>{project.label}</figcaption>
                <div
                  class="ba-toggle"
                  role="group"
                  aria-label={`Voor- of na-foto tonen van ${project.label}`}
                >
                  <button type="button" data-ba-show="voor" aria-pressed="false">Voor</button>
                  <button type="button" data-ba-show="na" aria-pressed="true">Na</button>
                </div>
              </div>
            </figure>
          ))
        }
      </div>
      <div class="galerij__footer" data-reveal>
        <a href="/projecten/" class="btn btn--secondary">Bekijk alle afgeronde projecten</a>
      </div>
    </div>
  </section>

  <!-- 6. Werkwijze -->
  <section class="section" aria-labelledby="werkwijze-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Werkwijze</p>
        <h2 id="werkwijze-title">Zo werkt het: vijf vaste stappen</h2>
        <p class="section-head__intro">
          Van eerste contact tot oplevering verloopt elk project via vijf vaste stappen – zonder
          verrassingen in planning of prijs. U ontvangt per stap een schriftelijke bevestiging.
        </p>
      </header>
      <ol class="steps" role="list" data-reveal-group>
        {
          stappen.map((stap) => (
            <li class="step">
              <div class="step__top">
                <span class="step__nr tabular" aria-hidden="true">{stap.nr}</span>
                <span class="step__icon" set:html={icons[stap.icon]} aria-hidden="true" />
              </div>
              <h3>{stap.titel}</h3>
              <p>{stap.tekst}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- 7. Garanties & keurmerken -->
  <section class="section section--alt" aria-labelledby="garanties-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Garanties</p>
        <h2 id="garanties-title">Afspraken die op papier staan</h2>
        <p class="section-head__intro">
          Stucq levert met vaste prijsgarantie en een schriftelijke opleveringsafspraak.
        </p>
      </header>
      <ul class="garanties" role="list" data-reveal-group>
        {
          garanties.map((garantie) => (
            <li class="garantie">
              <span class="garantie__icon" set:html={icons[garantie.icon]} aria-hidden="true" />
              <h3>{garantie.titel}</h3>
              <p>{garantie.tekst}</p>
            </li>
          ))
        }
      </ul>
      <p class="garanties__note" data-reveal>
        Keurmerken en branchevereniging-lidmaatschappen tonen wij hier zodra ze geverifieerd zijn.
      </p>
    </div>
  </section>

  <!-- 8. Reviews -->
  <section class="section" aria-labelledby="reviews-title">
    <div class="container reviews" data-reveal-group>
      <div class="review-score">
        <p class="review-score__num tabular">4,8</p>
        <p class="review-score__stars" aria-hidden="true">
          <span set:html={icons.star} />
          <span set:html={icons.star} />
          <span set:html={icons.star} />
          <span set:html={icons.star} />
          <span set:html={icons.starPartial} />
        </p>
        <p class="visually-hidden">4,8 van 5 sterren</p>
        <p class="review-score__sub">
          Gemiddelde score op Google, op basis van 25+ geverifieerde reviews.
        </p>
      </div>
      <div class="reviews__text">
        <p class="eyebrow">Reviews</p>
        <h2 id="reviews-title">Beoordeeld met 4,8 sterren op Google</h2>
        <p>
          25+ geverifieerde reviews van particulieren en bouwbedrijven uit Haarlem en omgeving.
        </p>
        <p>
          De beoordelingen gaan over planning, prijs en afwerking – bij gevelwerk, binnenafwerking
          en microcement vloeren.
        </p>
      </div>
    </div>
  </section>

  <!-- 9. CTA-band -->
  <section class="cta-band" aria-labelledby="cta-title">
