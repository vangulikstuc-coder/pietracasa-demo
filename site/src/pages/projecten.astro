<script>
  // Galerij filteren op dienst-categorie.
  const filterGroup = document.querySelector<HTMLElement>('[data-filter-group]');
  if (filterGroup) {
    const buttons = Array.from(filterGroup.querySelectorAll<HTMLButtonElement>('[data-filter]'));
    const kaarten = Array.from(document.querySelectorAll<HTMLElement>('[data-cat]'));
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.filter;
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        kaarten.forEach((kaart) => {
          kaart.hidden = cat !== 'alle' && kaart.dataset.cat !== cat;
        });
      });
    });
  }

  // Voor-na toggles in de projectgalerij.
  document.querySelectorAll<HTMLElement>('[data-ba]').forEach((card) => {
    const buttons = Array.from(card.querySelectorAll<HTMLButtonElement>('[data-ba-show]'));
    const panels = Array.from(card.querySelectorAll<HTMLElement>('[data-ba-panel]'));
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.baShow;
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        panels.forEach((panel) => {
          const active = panel.dataset.baPanel === target;
          panel.classList.toggle('is-active', active);
          panel.setAttribute('aria-hidden', String(!active));
        });
      });
    });
  });
</script>
