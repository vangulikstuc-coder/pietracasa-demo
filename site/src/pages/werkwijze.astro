---
import { Picture, Image, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ctaSfeer from '../assets/images/sections/cta-sfeer.jpg';
import bgStucLicht from '../assets/images/backgrounds/bg-stuc-licht.jpg';
import fotoStap1 from '../assets/images/sections/stap-1-opname.jpg';
import fotoStap2 from '../assets/images/sections/stap-2-offerte.jpg';
import fotoStap3 from '../assets/images/sections/stap-3-planning.jpg';
import fotoStap4 from '../assets/images/sections/stap-4-uitvoering.jpg';
import fotoStap5 from '../assets/images/sections/stap-5-oplevering.jpg';

const stapFotos = [fotoStap1, fotoStap2, fotoStap3, fotoStap4, fotoStap5];

const ogImage = await getImage({ src: ctaSfeer, width: 1200, format: 'jpg' });

const stappen = [
  {
    nr: '01',
    titel: 'Opname op locatie',
    tekst:
      'U vraagt een offerte aan via het formulier of telefonisch. Binnen 48 uur reageren wij en plannen een vrijblijvende opname op locatie.',
    afspraak: 'Reactie binnen 48 uur',
    icon: 'pin',
  },
  {
    nr: '02',
    titel: 'Offerte met vaste prijs',
    tekst:
      'Na de opname ontvangt u een schriftelijke offerte: vaste prijs en een heldere werkomschrijving. Geen offerte zonder dat u akkoord bent met de aanpak.',
    afspraak: 'Vaste prijs op schrift',
    icon: 'document',
  },
  {
    nr: '03',
    titel: 'Planning op papier',
    tekst:
      'Vóór de start bevestigen wij de startdatum en opleverdatum schriftelijk. U weet wanneer het werk begint en wanneer het klaar is.',
    afspraak: 'Start- en opleverdatum op papier',
    icon: 'calendar',
  },
  {
    nr: '04',
    titel: 'Uitvoering volgens planning',
    tekst:
      'Eén vakman is uw aanspreekpunt van start tot oplevering. Meerwerk gebeurt alleen na uw schriftelijk akkoord – nooit achteraf op de factuur.',
    afspraak: 'Meerwerk alleen na uw akkoord',
    icon: 'roller',
  },
  {
    nr: '05',
    titel: 'Oplevering',
    tekst:
      'Wij lopen het werk samen met u na, punt voor punt. Pas als alles klopt, is het project afgerond – op de afgesproken datum, binnen de vaste prijs.',
    afspraak: 'Oplevering op de afgesproken datum',
    icon: 'check',
  },
];

const vastgelegd = [
  {
    icon: 'document',
    titel: 'Vaste prijs op schrift',
    tekst: 'De offerteprijs is de eindprijs. Geen stelposten of open eindjes.',
  },
  {
    icon: 'calendar',
    titel: 'Start- en opleverdatum',
    tekst: 'Beide data staan vóór de start zwart op wit in de planning.',
  },
  {
    icon: 'shield',
    titel: 'Meerwerk alleen na akkoord',
    tekst: 'Wijzigingen worden eerst voorgelegd, schriftelijk, met prijs erbij.',
  },
];

const starPath =
  'M12 2.8l2.85 5.78 6.38.93-4.62 4.5 1.09 6.36L12 17.37l-5.7 3 1.09-6.36-4.62-4.5 6.38-.93L12 2.8z';

const icons: Record<string, string> = {
  star: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="${starPath}"/></svg>`,
  starPartial: `<svg viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="star-partial-grad"><stop offset="0.8" stop-color="currentColor"/><stop offset="0.8" stop-color="transparent"/></linearGradient></defs><path d="${starPath}" fill="url(#star-partial-grad)" stroke="currentColor" stroke-width="1"/></svg>`,
  check:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 12.5l5 5 10-11"/></svg>',
  pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>',
  document:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>',
  calendar:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/><path d="m9.5 15.5 2 2 3.5-4"/></svg>',
  roller:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="13" height="6" rx="2"/><path d="M16 6h4v4h-8v4"/><path d="M12 14v6"/></svg>',
  shield:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="m9 11.5 2 2 4-4"/></svg>',
};
---

<BaseLayout
  title="Werkwijze – stucadoor in Haarlem | Stucq"
  description="Zo werkt Stucq: opname, vaste prijs op schrift, planning, uitvoering en oplevering. Vraag vrijblijvend een offerte aan – reactie binnen 48 uur."
  ogImage={ogImage.src}
>
  <!-- 1. Pagina-hero (tekstkop: geen eigen werkwijze-beeld beschikbaar) -->
  <section class="page-hero" aria-labelledby="werkwijze-title">
    <div class="bg-drift" aria-hidden="true"></div>
    <div class="page-hero__texture" aria-hidden="true">
      <Picture
        data-parallax
        data-parallax-speed="7"
        src={bgStucLicht}
        widths={[768, 1280, 1536]}
        sizes="100vw"
        formats={['avif', 'webp']}
        alt=""
        loading="eager"
        decoding="async"
        data-demo="true"
      />
    </div>
    <div class="container page-hero__inner">
      <p class="eyebrow">Werkwijze</p>
      <h1 id="werkwijze-title">Van offerte tot oplevering in vijf vaste stappen</h1>
      <p class="page-hero__sub">
        Geen verrassingen in prijs of planning. Elke stap wordt schriftelijk bevestigd – u weet
        vooraf wat het kost en wanneer het klaar is.
      </p>
      <div class="page-hero__actions">
        <a href="/offerte-aanvragen/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="tel:0681943404" class="page-hero__tel">Bel voor advies: 06 81 94 34 04</a>
      </div>
      <p class="page-hero__micro">Vrijblijvend – vaste prijs, reactie binnen 48 uur.</p>
    </div>
  </section>

  <!-- 2. Kern-inhoud: vijf stappen als tijdlijn -->
  <section class="section" aria-labelledby="stappen-title">
    <div class="container tijdlijn-grid">
      <header class="tijdlijn-intro" data-reveal>
        <p class="eyebrow">De vijf stappen</p>
        <h2 id="stappen-title">Zo verloopt uw project</h2>
        <p class="tijdlijn-intro__tekst">
          Elk project sinds 2020 doorloopt dezelfde vijf stappen. Per stap ziet u welke afspraak
          vastligt – op papier, vóórdat de volgende stap begint.
        </p>
      </header>
      <ol class="tijdlijn" role="list" data-reveal-group>
        {
          stappen.map((stap, i) => (
            <li class="tl-stap">
              <div class="tl-stap__rail" aria-hidden="true">
                <span class="tl-stap__medaillon">
                  <Image
                    src={stapFotos[i]}
                    alt=""
                    width={192}
                    height={192}
                    loading="lazy"
                    decoding="async"
                    data-demo="true"
                  />
                </span>
                <span class="tl-stap__icon" set:html={icons[stap.icon]} />
              </div>
              <div class="tl-stap__body">
                <p class="tl-stap__nr tabular" aria-hidden="true">
                  {stap.nr}
                </p>
                <h3>{stap.titel}</h3>
                <p class="tl-stap__tekst">{stap.tekst}</p>
                <p class="tl-stap__afspraak">
                  <span class="tl-stap__afspraak-label">Afspraak</span>
                  {stap.afspraak}
                </p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- 3. Bewijs: wat ligt vast + reviewscore -->
  <section class="section section--alt" aria-labelledby="bewijs-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Bewijs</p>
        <h2 id="bewijs-title">Afspraken die aantoonbaar worden nagekomen</h2>
        <p class="section-head__intro">
          50+ projecten in Haarlem en omgeving sinds 2020 – allemaal op tijd en in budget
          opgeleverd. Dit ligt bij elk project vast.
        </p>
      </header>
      <div class="bewijs" data-reveal-group>
        <ul class="vastgelegd" role="list">
          {
            vastgelegd.map((item) => (
              <li class="vastgelegd__item">
                <span class="vastgelegd__icon" set:html={icons[item.icon]} aria-hidden="true" />
                <div>
                  <h3>{item.titel}</h3>
                  <p>{item.tekst}</p>
                </div>
              </li>
            ))
          }
          <li class="vastgelegd__item vastgelegd__item--link">
            <a href="/projecten/" class="btn btn--secondary">Bekijk alle afgeronde projecten</a>
          </li>
        </ul>
        <div class="review-score">
          <p class="review-score__num tabular">4,8</p>
          <p class="review-score__stars" aria-hidden="true">
            <span set:html={icons.star} />
            <span set:html={icons.star} />
            <span set:html={icons.star} />
            <span set:html={icons.star} />
            <span set:html={icons.starPartial} />
          </p>
          <p class="visually-hidden">4,8 van 5 sterren</p>
          <p class="review-score__sub">
            Gemiddelde score op Google, op basis van 25+ geverifieerde reviews. De beoordelingen
            gaan over planning, prijs en afwerking.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. CTA-band -->
  <section class="cta-band" aria-labelledby="cta-title">
    <div class="cta-band__bg" aria-hidden="true">
      <Picture
        src={ctaSfeer}
        widths={[820, 1280, 1920]}
        sizes="100vw"
        formats={['avif', 'webp']}
        alt=""
        loading="lazy"
        decoding="async"
        data-demo="true"
      />
    </div>
    <div class="sheen" aria-hidden="true"></div>
    <div class="container cta-band__inner" data-reveal>
      <h2 id="cta-title">Weten waar u aan toe bent?</h2>
      <p class="cta-band__sub">
        Vraag een vrijblijvende offerte aan – vaste prijs, reactie binnen 48 uur. Stap één begint
        vandaag.
      </p>
      <div class="cta-band__actions">
        <a href="/offerte-aanvragen/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="tel:0681943404" class="cta-band__tel">Bel direct: 06 81 94 34 04</a>
      </div>
      <p class="cta-band__micro">
        Vrijblijvend – vaste prijs, reactie binnen 48 uur. Bereikbaar ma–vr 7:00–17:00.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Gedeelde sectie-koppen --- */
  .eyebrow {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .section-head {
    max-width: 68ch;
    margin-block-end: clamp(var(--spacing-xl), 6vw, var(--spacing-2xl));
  }

  .section-head h2 {
    margin-block-start: var(--spacing-md);
  }

  .section-head__intro {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
  }

  /* --- 1. Pagina-hero (tekstkop met rustige gloed) --- */
  .page-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(var(--spacing-2xl), 9vw, var(--spacing-section));
    border-bottom: 1px solid var(--color-border-default);
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      80% 120% at 85% 0%,
      color-mix(in srgb, var(--color-primary-default) 7%, transparent),
      transparent 60%
    );
  }

  /* Stucwerk-textuur als hoek-accent rechtsboven (demo-beeld bg-stuc-licht) */
  .page-hero__texture {
    position: absolute;
    inset: 0;
  }

  .page-hero__texture :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .page-hero__texture :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Counter-scrim: dekt de textuur volledig af waar tekst staat (alleen de lege
     rechterbovenhoek blijft zichtbaar), zodat het tekstcontrast exact gelijk
     blijft aan de kale achtergrond. Bovenste laag herstelt de rustige gloed. */
  .page-hero__texture::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        80% 120% at 85% 0%,
        color-mix(in srgb, var(--color-primary-default) 7%, transparent),
        transparent 60%
      ),
      radial-gradient(55% 45% at 100% 0%, transparent, var(--color-background-default) 68%);
  }

  .page-hero__inner {
    position: relative;
  }

  .page-hero h1 {
    margin-block-start: var(--spacing-md);
    max-width: 22ch;
  }

  .page-hero__sub {
    margin-block-start: var(--spacing-md);
    font-size: clamp(var(--font-size-base), 2.5vw, var(--font-size-md));
    color: var(--color-text-secondary);
    max-width: 54ch;
  }

  .page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md) var(--spacing-lg);
    margin-block-start: var(--spacing-xl);
  }

  .page-hero__actions .btn {
    width: 100%;
  }

  @media (min-width: 640px) {
    .page-hero__actions .btn {
      width: auto;
    }
  }

  .page-hero__tel {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .page-hero__tel:hover {
    color: var(--color-primary-default);
  }

  .page-hero__micro {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  /* --- 2. Tijdlijn --- */
  .tijdlijn-grid {
    display: grid;
    gap: var(--spacing-xl);
    align-items: start;
  }

  .tijdlijn-intro h2 {
    margin-block-start: var(--spacing-md);
  }

  .tijdlijn-intro__tekst {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
    max-width: 48ch;
  }

  @media (min-width: 1024px) {
    .tijdlijn-grid {
      grid-template-columns: 0.8fr 1.2fr;
      gap: var(--spacing-2xl);
    }

    .tijdlijn-intro {
      position: sticky;
      top: calc(64px + var(--spacing-xl));
    }
  }

  .tijdlijn {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tl-stap {
    position: relative;
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: var(--spacing-lg);
  }

  .tl-stap:not(:last-child) {
    padding-block-end: clamp(var(--spacing-xl), 5vw, var(--spacing-2xl));
  }

  .tl-stap__rail {
    position: relative;
    display: flex;
    justify-content: center;
  }

  /* Foto-medaillon per stap (demo-beeld), icoon als klein badge eroverheen */
  .tl-stap__medaillon {
    position: relative;
    display: block;
    width: 76px;
    height: 76px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-surface-default);
    box-shadow: 0 6px 18px rgb(33 27 21 / 0.14);
    background: var(--color-surface-alt);
  }

  .tl-stap__medaillon :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 1024px) {
    .tl-stap {
      grid-template-columns: 96px 1fr;
    }

    .tl-stap__medaillon {
      width: 96px;
      height: 96px;
    }
  }

  /* Verbindingslijn tussen de stappen */
  .tl-stap:not(:last-child) .tl-stap__rail::after {
    content: '';
    position: absolute;
    inset-block: 84px 0;
    inline-size: 1px;
    background: var(--color-border-strong);
  }

  .tl-stap__icon {
    position: absolute;
    inset-block-end: -6px;
    inset-inline-end: -6px;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--color-surface-default);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
  }

  .tl-stap__icon :global(svg) {
    width: 16px;
    height: 16px;
  }

  .tl-stap__nr {
    font-family: var(--font-display);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  .tl-stap__body h3 {
    margin-block-start: var(--spacing-xs);
    font-size: var(--font-size-md);
  }

  .tl-stap__tekst {
    margin-block-start: var(--spacing-sm);
    color: var(--color-text-secondary);
    max-width: 52ch;
  }

  .tl-stap__afspraak {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-sm);
    margin-block-start: var(--spacing-md);
    padding: var(--spacing-xs) var(--spacing-md) var(--spacing-xs) var(--spacing-xs);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-pill);
    background: var(--color-surface-default);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  .tl-stap__afspraak-label {
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* --- 3. Bewijs --- */
  .bewijs {
    display: grid;
    gap: var(--spacing-xl);
    align-items: start;
  }

  .vastgelegd {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .vastgelegd__item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    padding-block: var(--spacing-lg);
    border-top: 1px solid var(--color-border-default);
  }

  .vastgelegd__item:last-child {
    border-bottom: 1px solid var(--color-border-default);
  }

  .vastgelegd__item--link {
    justify-content: flex-start;
  }

  .vastgelegd__icon {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
  }

  .vastgelegd__icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .vastgelegd__item h3 {
    font-size: var(--font-size-base);
  }

  .vastgelegd__item p {
    margin-block-start: var(--spacing-xs);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    max-width: 48ch;
  }

  .review-score {
    background: var(--color-neutral-900);
    color: var(--color-text-inverse);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: clamp(var(--spacing-lg), 5vw, var(--spacing-2xl));
  }

  .review-score__num {
    font-family: var(--font-display);
    font-size: clamp(var(--font-size-display), 10vw, 80px);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .review-score__stars {
    display: flex;
    gap: var(--spacing-xs);
    margin-block-start: var(--spacing-md);
    color: var(--color-text-inverse);
  }

  .review-score__stars :global(svg) {
    width: 22px;
    height: 22px;
  }

  .review-score__sub {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--color-neutral-300);
    max-width: 32ch;
  }

  @media (min-width: 900px) {
    .bewijs {
      grid-template-columns: 1.2fr 0.8fr;
      gap: var(--spacing-2xl);
    }
  }

  /* --- 4. CTA-band --- */
  .cta-band {
    position: relative;
    overflow: hidden;
    padding-block: clamp(var(--spacing-section), 14vw, 160px);
    color: var(--color-text-inverse);
  }

  .cta-band__bg {
    position: absolute;
    inset: 0;
  }

  .cta-band__bg :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .cta-band__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* AA-contrast: op mobiel loopt de tekst tot de rechterrand — daar blijft de scrim dekkend */
  .cta-band__bg::after {
