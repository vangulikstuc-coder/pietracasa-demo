---
import { Picture, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import heroBinnenafwerking from '../../assets/images/hero/hero-binnenafwerking.jpg';
import dienstBinnenafwerking from '../../assets/images/sections/dienst-binnenafwerking.jpg';
import galerijBinnenVoor from '../../assets/images/sections/galerij-binnen-voor.jpg';
import galerijBinnenNa from '../../assets/images/sections/galerij-binnen-na.jpg';
import ctaSfeer from '../../assets/images/sections/cta-sfeer.jpg';

/* Hero als 50/50-split uit de losse voor/na-helften: de deellijn ligt daardoor
   op elk breakpoint exact op het midden (composiet hero-binnenafwerking.jpg is alleen nog OG-beeld) */
const heroHalfWidths = [320, 640, 960, 1248];
const heroHalfSizes = '(min-width: 1024px) 28vw, 50vw';
const heroPreloadSrcsets = await Promise.all(
  [galerijBinnenVoor, galerijBinnenNa].map(async (src) => {
    const images = await Promise.all(
      heroHalfWidths.map(async (width) => ({
        width,
        image: await getImage({ src, width, format: 'avif' }),
      }))
    );
    return images.map(({ width, image }) => `${image.src} ${width}w`).join(', ');
  })
);

const ogImage = await getImage({ src: heroBinnenafwerking, width: 1200, format: 'jpg' });

const cardWidths = [420, 840];
const cardSizes = '(min-width: 900px) 45vw, 100vw';

const oplossingen = [
  {
    titel: 'Vaste prijsafspraak',
    tekst: 'De offerteprijs is de eindprijs. Meerwerk alleen na uw schriftelijk akkoord.',
    icon: 'euro',
  },
  {
    titel: 'Afgesproken deadline',
    tekst: '50+ projecten sinds 2020, allemaal binnen de afgesproken planning opgeleverd.',
    icon: 'clock',
  },
  {
    titel: 'Aantoonbaar bewijs',
    tekst: '4,8 sterren op Google, 25+ geverifieerde reviews en voor-na beelden per project.',
    icon: 'badge',
  },
];

const diensten = [
  {
    titel: 'Plafondafwerking',
    tekst: 'Strakke plafonds, egaal en schilderklaar opgeleverd.',
    icon: 'plafond',
  },
  {
    titel: 'Muurafwerking',
    tekst: 'Wanden vlak gezet, zonder zichtbare naden of oneffenheden.',
    icon: 'muur',
  },
  {
    titel: 'Gladstrijken',
    tekst: 'Bestaand stucwerk glad gezet, klaar voor verf of behang.',
    icon: 'spaan',
  },
  {
    titel: 'Spuitwerk',
    tekst: 'Egale spuitafwerking voor plafonds en wanden, in één planning.',
    icon: 'spuit',
  },
  {
    titel: 'Herstelwerk',
    tekst: 'Scheuren en gaten hersteld vóór de nieuwe afwerklaag.',
    icon: 'herstel',
  },
  {
    titel: 'Decoratief stucwerk',
    tekst: 'Afwerking in structuur of kleur, vooraf afgestemd op uw interieur.',
    icon: 'structuur',
  },
];

const stappen = [
  {
    nr: '01',
    titel: 'Opname op locatie',
    tekst: 'U vraagt een offerte aan. Binnen 48 uur plannen wij een opname bij u op locatie.',
    icon: 'pin',
  },
  {
    nr: '02',
    titel: 'Offerte met vaste prijs',
    tekst: 'Na de opname ontvangt u een schriftelijke offerte met vaste prijs voor de afwerking.',
    icon: 'document',
  },
  {
    nr: '03',
    titel: 'Planning op papier',
    tekst: 'Start- en opleverdatum staan vóór de start zwart op wit.',
    icon: 'calendar',
  },
  {
    nr: '04',
    titel: 'Uitvoering volgens planning',
    tekst: 'Het werk start en eindigt op de datum uit de offerte. Meerwerk alleen na uw akkoord.',
    icon: 'roller',
  },
  {
    nr: '05',
    titel: 'Oplevering',
    tekst: 'U loopt het resultaat samen met de vakman na bij oplevering.',
    icon: 'contract',
  },
];

const garanties = [
  {
    titel: 'Vaste prijs',
    tekst: 'De prijs uit de offerte wijzigt niet. Meerwerk alleen na uw schriftelijk akkoord.',
    icon: 'euro',
  },
  {
    titel: 'Op tijd opgeleverd',
    tekst: '50+ projecten sinds 2020, allemaal op de afgesproken datum afgerond.',
    icon: 'clock',
  },
  {
    titel: 'Garantie op het werk',
    tekst: 'Garantie op het geleverde werk, vastgelegd in de opleveringsafspraak.',
    icon: 'shield',
  },
];

const starPath =
  'M12 2.8l2.85 5.78 6.38.93-4.62 4.5 1.09 6.36L12 17.37l-5.7 3 1.09-6.36-4.62-4.5 6.38-.93L12 2.8z';

const icons: Record<string, string> = {
  star: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="${starPath}"/></svg>`,
  starPartial: `<svg viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="star-partial-grad"><stop offset="0.8" stop-color="currentColor"/><stop offset="0.8" stop-color="transparent"/></linearGradient></defs><path d="${starPath}" fill="url(#star-partial-grad)" stroke="currentColor" stroke-width="1"/></svg>`,
  euro: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.5 7a6.5 6.5 0 1 0 0 10"/><path d="M5 10.5h8M5 13.5h8"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg>',
  badge:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="9" r="6"/><path d="m9.5 9 1.8 1.8L15 7.2"/><path d="M8.5 13.5 7 22l5-3 5 3-1.5-8.5"/></svg>',
  shield:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="m9 11.5 2 2 4-4"/></svg>',
  pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>',
  calendar:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/><path d="m9.5 15.5 2 2 3.5-4"/></svg>',
  document:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>',
  roller:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="13" height="6" rx="2"/><path d="M16 6h4v4h-8v4"/><path d="M12 14v6"/></svg>',
  contract:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg>',
  phone:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  mail: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>',
  plafond:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18"/><path d="M8 6.5h.01M12 6.5h.01M16 6.5h.01"/></svg>',
  muur: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="1.5"/><path d="M3 12h18"/><path d="M12 5v7M7.5 12v7M16.5 12v7"/></svg>',
  spaan:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 5h12a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><path d="M11 12v6a2 2 0 0 0 2 2"/></svg>',
  spuit:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="9" width="8" height="7" rx="1.5"/><path d="M11 11.5h3.5"/><path d="m18.5 8 2-1.2M19 12.5h2.5M18.5 17l2 1.2"/></svg>',
  herstel:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8.5 3 7 8l2.5 3L7.5 16l2 5"/><path d="m13 14 2.5 2.5L20 12"/></svg>',
  structuur:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8c3-2.6 6 2.6 9 0s6 2.6 9 0"/><path d="M3 15c3-2.6 6 2.6 9 0s6 2.6 9 0"/></svg>',
};
---

<BaseLayout
  title="Binnenafwerking in Haarlem | Stucq"
  description="Binnenafwerking en renovatie in Haarlem op vaste prijs. Bekijk voor-na resultaten van wanden en plafonds en vraag vrijblijvend een offerte aan."
  ogImage={ogImage.src}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    type="image/avif"
    imagesrcset={heroPreloadSrcsets[0]}
    imagesizes={heroHalfSizes}
  />
  <link
    slot="head"
    rel="preload"
    as="image"
    type="image/avif"
    imagesrcset={heroPreloadSrcsets[1]}
    imagesizes={heroHalfSizes}
  />

  <!-- 1. Hero – Binnenafwerking -->
  <section class="hero" aria-labelledby="binnen-title">
    <div class="container hero__grid">
      <div class="hero__content" data-reveal>
        <p class="eyebrow">Binnenafwerking &amp; renovatie</p>
        <h1 id="binnen-title">Binnenafwerking in Haarlem – strak opgeleverd, op vaste prijs</h1>
        <p class="hero__sub">
          Wanden en plafonds netjes afgewerkt bij renovatie en nieuwbouwoplevering. U ontvangt
          vooraf een vaste prijs op schrift – en Stucq houdt zich daaraan.
        </p>
        <p class="hero__badge">
          <span class="hero__badge-icon" set:html={icons.shield} aria-hidden="true" />
          Vrijblijvend – vaste prijs, reactie binnen 48 uur
        </p>
        <div class="hero__actions">
          <a href="/offerte-aanvragen/" class="btn btn--primary">
            Offerte aanvragen
            <span class="btn__arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href="tel:0681943404" class="hero__tel">Bel voor advies: 06 81 94 34 04</a>
        </div>
      </div>
      <div class="hero__media">
        <div class="hero__split">
          <Picture
            src={galerijBinnenVoor}
            widths={heroHalfWidths}
            sizes={heroHalfSizes}
            formats={['avif', 'webp']}
            alt="Vóór: woonkamer met kale muren en beschadigd pleisterwerk"
            fetchpriority="high"
            loading="eager"
            data-demo="true"
          />
          <Picture
            src={galerijBinnenNa}
            widths={heroHalfWidths}
            sizes={heroHalfSizes}
            formats={['avif', 'webp']}
            alt="Na: dezelfde woonkamer met strak gestuukte wanden"
            fetchpriority="high"
            loading="eager"
            data-demo="true"
          />
        </div>
        <p class="hero__chip">Voor en na · binnenafwerking Haarlem</p>
      </div>
    </div>
  </section>

  <!-- 2. Probleemherkenning – Angst en oplossing -->
  <section class="section section--alt" aria-labelledby="probleem-title">
    <div class="container probleem" data-reveal-group>
      <div class="probleem__text">
        <p class="eyebrow">Herkenbaar</p>
        <h2 id="probleem-title">Onduidelijke offertes en gemiste deadlines</h2>
        <p>
          Twee klachten keren bij renovaties steeds terug: een offerte die achteraf hoger uitvalt
          en een planning die schuift. Stucq elimineert beide systematisch.
        </p>
        <p>
          Elke afspraak staat vóór de start op papier. Het trackrecord: 50+ projecten in Haarlem
          en omgeving sinds 2020, op tijd en in budget.
        </p>
      </div>
      <ul class="oplossingen" role="list">
        {
          oplossingen.map((item) => (
            <li class="oplossingen__item">
              <span class="oplossingen__icon" set:html={icons[item.icon]} aria-hidden="true" />
              <div>
                <h3>{item.titel}</h3>
                <p>{item.tekst}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 3. Dienstaanbod Binnenafwerking -->
  <section class="section" aria-labelledby="aanbod-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Het aanbod</p>
        <h2 id="aanbod-title">Binnenafwerking van plafond tot plint</h2>
        <p class="section-head__intro">
          Van gladstrijken en spuitwerk tot plafondafwerking en herstelwerk. Elke deeldienst wordt
          uitgevoerd op vaste prijs, met een vastgelegde opleverdatum.
        </p>
      </header>
      <ul class="aanbod" role="list" data-reveal-group>
        {
          diensten.map((dienst) => (
            <li class="aanbod__card">
              <span class="aanbod__icon" set:html={icons[dienst.icon]} aria-hidden="true" />
              <h3>{dienst.titel}</h3>
              <p>{dienst.tekst}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 4. Voor-na Projectbeelden -->
  <section class="section section--alt" aria-labelledby="galerij-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Projectbewijs</p>
        <h2 id="galerij-title">Binnenafwerking – voor, tijdens en na</h2>
        <p class="section-head__intro">
          Een selectie uit 50+ afgeronde projecten in Haarlem en omgeving – elk opgeleverd op de
          afgesproken datum en binnen budget. Wissel tussen de voor- en na-foto.
        </p>
      </header>
      <div class="galerij" data-reveal-group>
        <figure class="ba-card" data-ba>
          <div class="ba-card__media">
            <div class="ba-card__panel is-active" data-ba-panel="na">
              <Picture
                src={galerijBinnenNa}
                widths={cardWidths}
                sizes={cardSizes}
                formats={['avif', 'webp']}
                alt="Na: strak gestuukte wand en plafond in een woonkamer"
                loading="lazy"
                decoding="async"
                data-demo="true"
              />
            </div>
            <div class="ba-card__panel" data-ba-panel="voor" aria-hidden="true">
              <Picture
                src={galerijBinnenVoor}
                widths={cardWidths}
                sizes={cardSizes}
                formats={['avif', 'webp']}
                alt="Voor: beschadigde wand met oneffenheden en oude afwerklagen"
                loading="lazy"
                decoding="async"
                data-demo="true"
              />
            </div>
          </div>
          <div class="ba-card__bar">
            <figcaption>Binnenafwerking · Haarlem</figcaption>
            <div class="ba-toggle" role="group" aria-label="Voor- of na-foto tonen">
              <button type="button" data-ba-show="voor" aria-pressed="false">Voor</button>
              <button type="button" data-ba-show="na" aria-pressed="true">Na</button>
            </div>
          </div>
        </figure>
        <figure class="werkfoto">
          <div class="werkfoto__media">
            <Picture
              src={dienstBinnenafwerking}
              widths={cardWidths}
              sizes={cardSizes}
              formats={['avif', 'webp']}
              alt="Tijdens: vakman pleistert een binnenwand"
              loading="lazy"
              decoding="async"
              data-demo="true"
            />
          </div>
          <figcaption class="werkfoto__bar">Tijdens de uitvoering · regio Haarlem</figcaption>
        </figure>
      </div>
      <div class="galerij__more" data-reveal>
        <a href="/projecten/" class="btn btn--secondary">Bekijk alle afgeronde projecten</a>
      </div>
    </div>
  </section>

  <!-- 5. Sociaal bewijs – Google-reviews -->
  <section class="section" aria-labelledby="reviews-title">
    <div class="container reviews" data-reveal-group>
      <div class="review-score">
        <p class="review-score__num tabular">4,8</p>
        <p class="review-score__stars" aria-hidden="true">
          <span set:html={icons.star} />
          <span set:html={icons.star} />
          <span set:html={icons.star} />
          <span set:html={icons.star} />
          <span set:html={icons.starPartial} />
        </p>
        <p class="visually-hidden">4,8 van 5 sterren</p>
        <p class="review-score__sub">
          Gemiddelde score op Google, op basis van 25+ geverifieerde reviews.
        </p>
      </div>
      <div class="reviews__text">
        <p class="eyebrow">Reviews</p>
        <h2 id="reviews-title">Beoordeeld met 4,8 sterren op Google</h2>
        <p>
          25+ geverifieerde reviews van bouwbedrijven en huiseigenaren in Haarlem die Stucq
          inschakelden voor renovatie en nieuwbouw.
        </p>
        <p>
          De beoordelingen gaan over planning, prijs en afwerking – ook bij binnenafwerking en
          herstelwerk.
        </p>
      </div>
    </div>
  </section>

  <!-- 6. Werkwijze – Stap voor stap -->
  <section class="section section--alt" aria-labelledby="werkwijze-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Werkwijze</p>
        <h2 id="werkwijze-title">Van eerste contact tot oplevering – vijf vaste stappen</h2>
        <p class="section-head__intro">
          Prijs en planning zijn vooraf overeengekomen. Zo weet u bij elke stap waar u aan toe
          bent.
        </p>
      </header>
      <ol class="stappen" role="list" data-reveal-group>
        {
          stappen.map((stap) => (
            <li class="stap">
              <div class="stap__top">
                <span class="stap__icon" set:html={icons[stap.icon]} aria-hidden="true" />
                <span class="stap__nr tabular" aria-hidden="true">
                  {stap.nr}
                </span>
              </div>
              <h3>{stap.titel}</h3>
              <p>{stap.tekst}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- 7. Werkgebied & Beschikbaarheid -->
  <section class="section" aria-labelledby="werkgebied-title">
    <div class="container werkgebied" data-reveal-group>
      <div class="werkgebied__text">
        <p class="eyebrow">Werkgebied</p>
        <h2 id="werkgebied-title">Haarlem, Bloemendaal, Zandvoort en omgeving</h2>
        <p>
          Stucq voert binnenafwerkingsprojecten uit in Haarlem, Bloemendaal, Zandvoort en omgeving
          tot 15 km. Voor bouwbedrijven, vastgoedprojecten en particuliere woningen.
        </p>
        <ul class="werkgebied__plaatsen" role="list">
          <li>Haarlem</li>
          <li>Bloemendaal</li>
          <li>Zandvoort</li>
          <li>Omgeving tot 15 km</li>
        </ul>
      </div>
      <div class="werkgebied__contact">
        <h3>Bereikbaarheid</h3>
        <ul role="list">
          <li>
            <span class="werkgebied__icon" set:html={icons.phone} aria-hidden="true" />
            <a href="tel:0681943404">06 81 94 34 04</a>
          </li>
          <li>
            <span class="werkgebied__icon" set:html={icons.mail} aria-hidden="true" />
            <a href="mailto:info@stucqafbouw.nl">info@stucqafbouw.nl</a>
          </li>
          <li>
            <span class="werkgebied__icon" set:html={icons.clock} aria-hidden="true" />
            <span>Werkdagen 7:00–17:00 · spoedopdrachten mogelijk binnen 48 uur</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 8. Garanties & Keurmerken -->
  <section class="section section--alt" aria-labelledby="garanties-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Garanties</p>
        <h2 id="garanties-title">Vastgelegd vóór de start, gecontroleerd bij oplevering</h2>
        <p class="section-head__intro">
          Elke opdracht wordt uitgevoerd met garantie op het geleverde werk en een vaste prijs die
          na de offerte niet wijzigt.
        </p>
      </header>
      <ul class="garanties" role="list" data-reveal-group>
        {
          garanties.map((garantie) => (
            <li class="garanties__item">
              <span class="garanties__icon" set:html={icons[garantie.icon]} aria-hidden="true" />
              <h3>{garantie.titel}</h3>
              <p>{garantie.tekst}</p>
            </li>
          ))
        }
