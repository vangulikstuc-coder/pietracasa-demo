---
import { Picture, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import heroMicrocement from '../../assets/images/hero/hero-microcement.jpg';
import dienstMicrocement from '../../assets/images/sections/dienst-microcement.jpg';
import galerijVloerVoor from '../../assets/images/sections/galerij-vloer-voor.jpg';
import galerijVloerNa from '../../assets/images/sections/galerij-vloer-na.jpg';
import ctaSfeer from '../../assets/images/sections/cta-sfeer.jpg';

const heroWidths = [768, 1280, 1920];
const heroSizes = '100vw';
const heroAvif = await Promise.all(
  heroWidths.map(async (width) => ({
    width,
    image: await getImage({ src: heroMicrocement, width, format: 'avif' }),
  }))
);
const heroPreloadSrcset = heroAvif.map(({ width, image }) => `${image.src} ${width}w`).join(', ');

const ogImage = await getImage({ src: heroMicrocement, width: 1200, format: 'jpg' });

const cardWidths = [420, 840];
const cardSizes = '(min-width: 900px) 45vw, 100vw';

const toepassingen = [
  {
    titel: 'Naadloze vloeren',
    tekst: 'Eén doorlopend oppervlak in woonkamer, keuken of hal – zonder voegen of overgangen.',
  },
  {
    titel: 'Badkamers en natte ruimtes',
    tekst: 'Waterbestendige afwerking voor vloer, wand en douchezone – naadloos doorgezet.',
  },
  {
    titel: 'Renovatie op bestaande ondergrond',
    tekst: 'In veel gevallen direct over bestaande tegels of dekvloer, zonder sloopwerk. Wij beoordelen de ondergrond bij de inspectie.',
  },
];

const vragen = [
  {
    icon: 'euro',
    vraag: 'Wat kost een microcement vloer?',
    antwoord:
      'U ontvangt na de inspectie op locatie een vaste prijs op schrift. De ondergrond en oppervlakte bepalen de prijs – en aan die prijs houdt Stucq zich.',
  },
  {
    icon: 'clock',
    vraag: 'Hoe lang duurt het aanbrengen?',
    antwoord:
      'Microcement wordt in meerdere lagen opgebouwd, met droogtijd per laag. De exacte planning staat in uw offerte en wordt nagekomen.',
  },
  {
    icon: 'layers',
    vraag: 'Kan microcement over mijn bestaande vloer?',
    antwoord:
      'In veel gevallen wel, ook over tegels. Wij beoordelen de ondergrond tijdens de inspectie en nemen de voorbereiding op in de vaste prijs.',
  },
  {
    icon: 'heat',
    vraag: 'Is microcement geschikt voor vloerverwarming?',
    antwoord:
      'Ja. De dunne, naadloze laag werkt goed samen met vloerverwarming. Wij stemmen de opbouw af op uw vloer.',
  },
];

const starPath =
  'M12 2.8l2.85 5.78 6.38.93-4.62 4.5 1.09 6.36L12 17.37l-5.7 3 1.09-6.36-4.62-4.5 6.38-.93L12 2.8z';

const icons: Record<string, string> = {
  star: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="${starPath}"/></svg>`,
  check:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 12.5l5 5 10-11"/></svg>',
  shield:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="m9 11.5 2 2 4-4"/></svg>',
  euro: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18.5 5.8A7.5 7.5 0 0 0 6.5 12a7.5 7.5 0 0 0 12 6.2"/><path d="M4 10.2h9M4 13.8h9"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg>',
  layers:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3 9 5-9 5-9-5z"/><path d="m3 13 9 5 9-5"/><path d="m3 17 9 5 9-5"/></svg>',
  heat: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 14.8V5a2 2 0 1 0-4 0v9.8a4 4 0 1 0 4 0z"/><path d="M12 9v7"/></svg>',
};

const feiten = [
  { icon: 'star', tekst: '4,8 sterren op Google – 25+ geverifieerde reviews' },
  { icon: 'check', tekst: '50+ projecten sinds 2020, op tijd en in budget' },
  { icon: 'shield', tekst: 'KvK-geregistreerd en verzekerd' },
];
---

<BaseLayout
  title="Microcement vloeren in Haarlem | Stucq"
  description="Microcement vloeren in Haarlem op vaste prijs. Naadloos resultaat voor vloer en wand. Bekijk voor-na resultaten en vraag vrijblijvend een offerte aan."
  ogImage={ogImage.src}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    type="image/avif"
    imagesrcset={heroPreloadSrcset}
    imagesizes={heroSizes}
  />

  <!-- 1. Pagina-hero -->
  <section class="page-hero" aria-labelledby="microcement-title">
    <div class="page-hero__bg" aria-hidden="true">
      <Picture
        src={heroMicrocement}
        widths={heroWidths}
        sizes={heroSizes}
        formats={['avif', 'webp']}
        alt=""
        fetchpriority="high"
        loading="eager"
        data-demo="true"
      />
    </div>
    <div class="container page-hero__inner">
      <p class="eyebrow eyebrow--inverse">Microcement vloeren</p>
      <h1 id="microcement-title">Microcement vloeren in Haarlem – naadloos, op vaste prijs</h1>
      <p class="page-hero__sub">
        Stucq brengt naadloze microcement vloeren en wanden aan in Haarlem en omgeving. U weet
        vooraf wat het kost – vaste prijs op schrift.
      </p>
      <div class="page-hero__actions">
        <a href="/offerte-aanvragen/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="tel:0681943404" class="page-hero__tel">Bel voor advies: 06 81 94 34 04</a>
      </div>
      <p class="page-hero__micro">Vrijblijvend – vaste prijs, reactie binnen 48 uur.</p>
    </div>
  </section>

  <!-- 2. Kern-inhoud: toepassingen -->
  <section class="section" aria-labelledby="dienst-title">
    <div class="container dienst" data-reveal-group>
      <div class="dienst__text">
        <p class="eyebrow">De dienst</p>
        <h2 id="dienst-title">Waar microcement geschikt voor is</h2>
        <p class="dienst__intro">
          Microcement is een dunne, naadloze afwerklaag voor vloeren en wanden. Eén vakman brengt
          de lagen aan en levert het oppervlak gebruiksklaar op.
        </p>
        <ol class="werklijst" role="list">
          {
            toepassingen.map((werk, i) => (
              <li class="werklijst__item">
                <span class="werklijst__nr tabular" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div>
                  <h3>{werk.titel}</h3>
                  <p>{werk.tekst}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
      <figure class="dienst__media">
        <Picture
          src={dienstMicrocement}
          widths={cardWidths}
          sizes={cardSizes}
          formats={['avif', 'webp']}
          alt="Vakman brengt een laag microcement aan op een vloer"
          loading="lazy"
          decoding="async"
          data-demo="true"
        />
      </figure>
    </div>
  </section>

  <!-- 2b. Kern-inhoud: kosten en doorlooptijd -->
  <section class="section section--alt" aria-labelledby="vragen-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Kosten &amp; doorlooptijd</p>
        <h2 id="vragen-title">Veelgestelde vragen over microcement</h2>
        <p class="section-head__intro">
          Geen open eindjes. De antwoorden hieronder gelden voor elk microcement-project dat Stucq
          aanneemt.
        </p>
      </header>
      <ul class="vragen" role="list" data-reveal-group>
        {
          vragen.map((item) => (
            <li class="vraag">
              <span class="vraag__icon" set:html={icons[item.icon]} aria-hidden="true" />
              <h3>{item.vraag}</h3>
              <p>{item.antwoord}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 3. Bewijs: voor-na + feiten -->
  <section class="section" aria-labelledby="bewijs-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Bewijs</p>
        <h2 id="bewijs-title">Het verschil van microcement – voor en na</h2>
        <p class="section-head__intro">
          Bekijk een afgeronde microcement vloer uit de regio Haarlem. Wissel tussen de voor- en
          na-foto.
        </p>
      </header>
      <div class="bewijs" data-reveal-group>
        <figure class="ba-card" data-ba>
          <div class="ba-card__media">
            <div class="ba-card__panel is-active" data-ba-panel="na">
              <Picture
                src={galerijVloerNa}
                widths={cardWidths}
                sizes={cardSizes}
                formats={['avif', 'webp']}
                alt="Na: naadloze microcement vloer, strak en egaal afgewerkt"
                loading="lazy"
                decoding="async"
                data-demo="true"
              />
            </div>
            <div class="ba-card__panel" data-ba-panel="voor" aria-hidden="true">
              <Picture
                src={galerijVloerVoor}
                widths={cardWidths}
                sizes={cardSizes}
                formats={['avif', 'webp']}
                alt="Voor: verouderde vloer met voegen vóór de microcement-afwerking"
                loading="lazy"
                decoding="async"
                data-demo="true"
              />
            </div>
          </div>
          <div class="ba-card__bar">
            <figcaption>Microcement vloer · regio Haarlem</figcaption>
            <div class="ba-toggle" role="group" aria-label="Voor- of na-foto tonen">
              <button type="button" data-ba-show="voor" aria-pressed="false">Voor</button>
              <button type="button" data-ba-show="na" aria-pressed="true">Na</button>
            </div>
          </div>
        </figure>
        <div class="bewijs__text">
          <p>
            Elke microcement vloer sinds 2020 is binnen budget en op de afgesproken datum
            opgeleverd. Niet als belofte, maar als trackrecord.
          </p>
          <ul class="bewijs__feiten" role="list">
            {
              feiten.map((feit) => (
                <li>
                  <span class="bewijs__icon" set:html={icons[feit.icon]} aria-hidden="true" />
                  {feit.tekst}
                </li>
              ))
            }
          </ul>
          <a href="/projecten/" class="btn btn--secondary">Bekijk alle afgeronde projecten</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. CTA-band -->
  <section class="cta-band" aria-labelledby="cta-title">
    <div class="cta-band__bg" aria-hidden="true">
      <Picture
        src={ctaSfeer}
        widths={[820, 1280, 1920]}
        sizes="100vw"
        formats={['avif', 'webp']}
        alt=""
        loading="lazy"
        decoding="async"
        data-demo="true"
      />
    </div>
    <div class="sheen" aria-hidden="true"></div>
    <div class="container cta-band__inner" data-reveal>
      <h2 id="cta-title">Een microcement vloer gepland in Haarlem of omgeving?</h2>
      <p class="cta-band__sub">
        Vraag een vrijblijvende offerte aan – vaste prijs, reactie binnen 48 uur.
      </p>
      <div class="cta-band__actions">
        <a href="/offerte-aanvragen/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="tel:0681943404" class="cta-band__tel">Bel direct: 06 81 94 34 04</a>
      </div>
      <p class="cta-band__micro">
        Vrijblijvend – vaste prijs, reactie binnen 48 uur. Bereikbaar ma–vr 7:00–17:00.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Gedeelde sectie-koppen --- */
  .eyebrow {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .eyebrow--inverse {
    color: var(--color-neutral-100);
  }

  .section-head {
    max-width: 68ch;
    margin-block-end: clamp(var(--spacing-xl), 6vw, var(--spacing-2xl));
  }

  .section-head h2 {
    margin-block-start: var(--spacing-md);
  }

  .section-head__intro {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
  }

  /* --- 1. Pagina-hero --- */
  .page-hero {
    position: relative;
    overflow: hidden;
    display: grid;
    align-items: end;
    min-height: clamp(440px, 60vh, 620px);
    padding-block: clamp(var(--spacing-2xl), 9vw, var(--spacing-section));
    color: var(--color-text-inverse);
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
  }

  .page-hero__bg :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .page-hero__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: hero-settle 1200ms cubic-bezier(0.22, 1, 0.36, 1) 250ms both;
  }

  /* Signature: gladstrijkende laag trekt van links naar rechts over het beeld */
  .page-hero__bg::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(100deg, var(--color-neutral-100), var(--color-neutral-300));
    transform-origin: right center;
    animation: hero-sweep 1000ms cubic-bezier(0.22, 1, 0.36, 1) 250ms both;
  }

  /* AA-contrast op licht beeld: mobiel beslaat de tekst bijna de hele hero (vlakkere scrim);
     desktop staat de tekst linksonder — daar extra dekking, rechtsboven blijft het beeld vrij */
  .page-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-neutral-900) 92%, transparent),
      color-mix(in srgb, var(--color-neutral-900) 78%, transparent) 50%,
      color-mix(in srgb, var(--color-neutral-900) 66%, transparent)
    );
  }

  @media (min-width: 768px) {
    .page-hero__bg::after {
      background:
        linear-gradient(
          to right,
          color-mix(in srgb, var(--color-neutral-900) 60%, transparent),
          color-mix(in srgb, var(--color-neutral-900) 32%, transparent) 45%,
          transparent 72%
        ),
        linear-gradient(
          to top,
          color-mix(in srgb, var(--color-neutral-900) 92%, transparent),
          color-mix(in srgb, var(--color-neutral-900) 74%, transparent) 42%,
          color-mix(in srgb, var(--color-neutral-900) 40%, transparent) 75%,
          color-mix(in srgb, var(--color-neutral-900) 18%, transparent)
        );
    }
  }

  @keyframes hero-sweep {
    from {
      transform: scaleX(1);
    }
    to {
      transform: scaleX(0);
    }
  }

  @keyframes hero-settle {
    from {
      transform: scale(1.06);
    }
    to {
      transform: scale(1);
    }
  }

  .page-hero__inner {
    position: relative;
    z-index: 3;
  }

  .page-hero h1 {
    margin-block-start: var(--spacing-md);
    max-width: 22ch;
  }

  .page-hero__sub {
    margin-block-start: var(--spacing-md);
    font-size: clamp(var(--font-size-base), 2.5vw, var(--font-size-md));
    color: var(--color-neutral-100);
    max-width: 54ch;
  }

  .page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md) var(--spacing-lg);
    margin-block-start: var(--spacing-xl);
  }

  .page-hero__actions .btn {
    width: 100%;
  }

  @media (min-width: 640px) {
    .page-hero__actions .btn {
      width: auto;
    }
  }

  .page-hero__tel {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-text-inverse);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .page-hero__tel:hover {
    color: var(--color-neutral-200);
  }

  .page-hero__micro {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--color-neutral-300);
  }

  /* --- 2. Dienst-blok --- */
  .dienst {
    display: grid;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .dienst__text h2 {
    margin-block-start: var(--spacing-md);
  }

  .dienst__intro {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
    max-width: 54ch;
  }

  .werklijst {
    list-style: none;
    margin: var(--spacing-xl) 0 0;
    padding: 0;
  }

  .werklijst__item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    padding-block: var(--spacing-md);
    border-top: 1px solid var(--color-border-default);
  }

  .werklijst__item:last-child {
    border-bottom: 1px solid var(--color-border-default);
  }

  .werklijst__nr {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
    font-family: var(--font-display);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-sm);
  }

  .werklijst__item h3 {
    font-size: var(--font-size-base);
  }

  .werklijst__item p {
    margin-block-start: var(--spacing-xs);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    max-width: 48ch;
  }

  .dienst__media {
    margin: 0;
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .dienst__media :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .dienst__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Crop-anker = gezicht van de vakman: de 4/5-crop houdt het hoofd in beeld */
    object-position: 54% 21%;
  }

  @media (min-width: 900px) {
    .dienst {
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--spacing-2xl);
    }
  }

  /* --- 2b. Vragen over kosten & doorlooptijd --- */
  .vragen {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--spacing-lg);
  }

  .vraag {
    background: var(--color-surface-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: var(--spacing-lg);
  }

  .vraag__icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
  }

  .vraag__icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .vraag h3 {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-md);
  }

  .vraag p {
    margin-block-start: var(--spacing-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    max-width: 48ch;
  }

  @media (min-width: 768px) {
    .vragen {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* --- 3. Bewijs --- */
  .bewijs {
    display: grid;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .ba-card {
    margin: 0;
    background: var(--color-surface-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .ba-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
  }

  .ba-card__panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--motion-base) var(--motion-easing);
  }

  .ba-card__panel.is-active {
    opacity: 1;
  }

  .ba-card__panel :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .ba-card__panel :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-card__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .ba-card__bar figcaption {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
  }

  .ba-toggle {
    display: inline-flex;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-pill);
    padding: var(--spacing-xs);
    gap: var(--spacing-xs);
  }

  .ba-toggle button {
    min-height: 36px;
    min-width: 56px;
    padding: var(--spacing-xs) var(--spacing-md);
    border: 0;
    border-radius: var(--radius-pill);
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition:
      background-color var(--motion-fast) var(--motion-easing),
      color var(--motion-fast) var(--motion-easing);
  }

  .ba-toggle button:hover {
    color: var(--color-text-primary);
  }

  .ba-toggle button:focus-visible {
    outline: 3px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  .ba-toggle button[aria-pressed='true'] {
    background: var(--color-neutral-900);
    color: var(--color-text-inverse);
  }

  .bewijs__text > p {
    color: var(--color-text-secondary);
    max-width: 48ch;
  }

  .bewijs__feiten {
    list-style: none;
    margin: var(--spacing-lg) 0;
    padding: var(--spacing-md) var(--spacing-lg);
    display: grid;
    gap: var(--spacing-md);
    background: var(--color-surface-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .bewijs__feiten li {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    font-weight: var(--font-weight-medium);
  }

  .bewijs__icon {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
  }

  .bewijs__icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  @media (min-width: 900px) {
    .bewijs {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--spacing-2xl);
    }
  }

  /* --- 4. CTA-band --- */
  .cta-band {
    position: relative;
    overflow: hidden;
    padding-block: clamp(var(--spacing-section), 14vw, 160px);
    color: var(--color-text-inverse);
  }

  .cta-band__bg {
    position: absolute;
    inset: 0;
  }

  .cta-band__bg :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .cta-band__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* AA-contrast: op mobiel loopt de tekst tot de rechterrand — daar blijft de scrim dekkend */
  .cta-band__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      color-mix(in srgb, var(--color-neutral-900) 86%, transparent),
      color-mix(in srgb, var(--color-neutral-900) 72%, transparent)
    );
  }

  @media (min-width: 768px) {
    .cta-band__bg::after {
      background: linear-gradient(
        100deg,
        color-mix(in srgb, var(--color-neutral-900) 86%, transparent),
        color-mix(in srgb, var(--color-neutral-900) 60%, transparent)
      );
    }
  }

  .cta-band__inner {
    position: relative;
    z-index: 1;
  }

  .cta-band__sub {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-md);
    color: var(--color-neutral-100);
    max-width: 46ch;
  }

  .cta-band__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-lg);
    margin-block-start: var(--spacing-xl);
  }

  .cta-band__tel {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-text-inverse);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .cta-band__tel:hover {
    color: var(--color-neutral-200);
  }

  .cta-band__micro {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--color-neutral-100);
  }
</style>

<script>
  // Voor-na toggle in het bewijsblok.
  document.querySelectorAll<HTMLElement>('[data-ba]').forEach((card) => {
    const buttons = Array.from(card.querySelectorAll<HTMLButtonElement>('[data-ba-show]'));
    const panels = Array.from(card.querySelectorAll<HTMLElement>('[data-ba-panel]'));
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.baShow;
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        panels.forEach((panel) => {
          const active = panel.dataset.baPanel === target;
          panel.classList.toggle('is-active', active);
          panel.setAttribute('aria-hidden', String(!active));
        });
      });
    });
  });
</script>
