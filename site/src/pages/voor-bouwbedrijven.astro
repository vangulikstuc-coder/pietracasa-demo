---
import { Picture, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import b2bOverleg from '../assets/images/sections/b2b-overleg.jpg';
import dienstGevelwerk from '../assets/images/sections/dienst-gevelwerk.jpg';
import ctaSfeer from '../assets/images/sections/cta-sfeer.jpg';

const ogImage = await getImage({ src: b2bOverleg, width: 1200, format: 'jpg' });

const cardWidths = [420, 840];
const cardSizes = '(min-width: 900px) 45vw, 100vw';

const proposities = [
  {
    titel: 'Planning die staat',
    tekst:
      'Uw bouwschema is leidend. 50+ projecten sinds 2020 zijn op de afgesproken datum opgeleverd – ook in onderaanneming. Loopt er iets in de keten, dan hoort u dat direct, niet achteraf.',
  },
  {
    titel: 'Eén aanspreekpunt',
    tekst:
      'U schakelt rechtstreeks met de vakman die het werk uitvoert. Korte lijnen, direct nummer, en op locatie iemand die beslissingen kan nemen.',
  },
  {
    titel: 'Vaste prijs, heldere facturatie',
    tekst:
      'Offerte per project of een m²-afspraak voor series. Meerwerk uitsluitend na schriftelijk akkoord – geen verrassingen op de eindfactuur.',
  },
  {
    titel: 'Kwaliteit geborgd',
    tekst:
      'KvK-geregistreerd en verzekerd. Elke oplevering wordt schriftelijk vastgelegd, zodat uw opleverdossier compleet is.',
  },
];

const werkzaamheden = [
  'Gevelwerk en buitenafwerking – nieuwbouw en renovatie',
  'Binnenafwerking: wanden en plafonds sausklaar of behangklaar',
  'Spuitwerk (latex) voor series en complete projecten',
  'Microcement en beton ciré voor hoogwaardige afwerking',
];
---

<BaseLayout
  title="Voor bouwbedrijven | Stucq"
  description="Stucq als vaste afbouwpartner voor bouwbedrijven en vastgoed in de regio Haarlem. Planning die staat, één aanspreekpunt en vaste prijzen per project of m²."
  ogImage={ogImage.src}
>
  <!-- 1. Hero -->
  <section class="b2b-hero" aria-labelledby="b2b-title">
    <div class="container b2b-hero__grid">
      <div class="b2b-hero__text" data-reveal>
        <p class="eyebrow">Voor bouwbedrijven</p>
        <h1 id="b2b-title">Een afbouwpartner die uw planning niet laat schuiven</h1>
        <p class="b2b-hero__sub">
          Stucq werkt voor bouwbedrijven en vastgoedpartijen in de regio Haarlem – in
          onderaanneming of rechtstreeks. Vaste prijzen, schriftelijke afspraken en een vakman
          die uw opleverdatum net zo serieus neemt als u.
        </p>
        <div class="b2b-hero__actions">
          <a href="/offerte-aanvragen/" class="btn btn--primary">
            Offerte aanvragen
            <span class="btn__arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href="tel:0681943404" class="b2b-hero__tel">Bel direct: 06 81 94 34 04</a>
        </div>
        <p class="b2b-hero__micro">Vrijblijvend – reactie binnen 48 uur, ook voor planningsvragen.</p>
      </div>
      <figure class="b2b-hero__media" data-reveal>
        <Picture
          src={b2bOverleg}
          widths={cardWidths}
          sizes={cardSizes}
          formats={['avif', 'webp']}
          alt="Vakman van Stucq overlegt met een projectleider op de bouwplaats"
          fetchpriority="high"
          loading="eager"
          data-demo="true"
        />
        <figcaption>Werkoverleg op locatie · regio Haarlem</figcaption>
      </figure>
    </div>
  </section>

  <!-- 2. Proposities -->
  <section class="section section--alt" aria-labelledby="propositie-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Waarom bouwbedrijven met Stucq werken</p>
        <h2 id="propositie-title">Afspraken waar u uw planning op kunt bouwen</h2>
      </header>
      <ul class="proposities" role="list" data-reveal-group>
        {
          proposities.map((p, i) => (
            <li class="propositie">
              <span class="propositie__nr tabular" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3>{p.titel}</h3>
              <p>{p.tekst}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 3. Werkzaamheden -->
  <section class="section" aria-labelledby="werk-title">
    <div class="container b2b-werk" data-reveal-group>
      <div class="b2b-werk__text">
        <p class="eyebrow">In onderaanneming</p>
        <h2 id="werk-title">Wat Stucq voor u uitvoert</h2>
        <ul class="b2b-werk__lijst" role="list">
          {werkzaamheden.map((w) => <li>{w}</li>)}
        </ul>
        <p class="b2b-werk__note">
          Series, projectmatig werk of losse adressen – de werkwijze blijft gelijk: opname,
          vaste prijs op schrift, uitvoering volgens uw schema en een schriftelijke oplevering.
        </p>
      </div>
      <figure class="b2b-werk__media">
        <Picture
          src={dienstGevelwerk}
          widths={cardWidths}
          sizes={cardSizes}
          formats={['avif', 'webp']}
          alt="Vakman stukadoort een gevel vanaf een steiger"
          loading="lazy"
          decoding="async"
          data-demo="true"
        />
      </figure>
    </div>
  </section>

  <!-- 4. CTA-band -->
  <section class="cta-band" aria-labelledby="cta-title">
    <div class="cta-band__bg" aria-hidden="true">
      <Picture
        src={ctaSfeer}
        widths={[820, 1280, 1920]}
        sizes="100vw"
        formats={['avif', 'webp']}
        alt=""
        loading="lazy"
        decoding="async"
        data-demo="true"
      />
    </div>
    <div class="sheen" aria-hidden="true"></div>
    <div class="container cta-band__inner" data-reveal>
      <h2 id="cta-title">Capaciteit nodig voor een lopend of komend project?</h2>
      <p class="cta-band__sub">
        Bel voor een kennismaking of planningscheck – u weet binnen één gesprek waar u aan toe
        bent.
      </p>
      <div class="cta-band__actions">
        <a href="/offerte-aanvragen/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="tel:0681943404" class="cta-band__tel">Bel direct: 06 81 94 34 04</a>
      </div>
      <p class="cta-band__micro">Bereikbaar ma–vr 7:00–17:00. Reactie binnen 48 uur.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .section-head {
    max-width: 68ch;
    margin-block-end: clamp(var(--spacing-xl), 6vw, var(--spacing-2xl));
  }

  .section-head h2 {
    margin-block-start: var(--spacing-md);
  }

  /* --- Hero --- */
  .b2b-hero {
    padding-block: clamp(var(--spacing-2xl), 9vw, var(--spacing-section));
    border-bottom: 1px solid var(--color-border-default);
  }

  .b2b-hero__grid {
    display: grid;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .b2b-hero h1 {
    margin-block-start: var(--spacing-md);
    max-width: 20ch;
  }

  .b2b-hero__sub {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
    max-width: 56ch;
  }

  .b2b-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md);
    margin-block-start: var(--spacing-lg);
  }

  .b2b-hero__tel {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-default);
  }

  .b2b-hero__micro {
    margin-block-start: var(--spacing-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .b2b-hero__media {
    margin: 0;
  }

  .b2b-hero__media :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: 0 18px 40px rgb(33 27 21 / 0.16);
  }

  .b2b-hero__media figcaption {
    margin-block-start: var(--spacing-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  @media (min-width: 900px) {
    .b2b-hero__grid {
      grid-template-columns: 1.05fr 0.95fr;
      gap: clamp(var(--spacing-xl), 5vw, var(--spacing-2xl));
    }
  }

  /* --- Proposities --- */
  .proposities {
    display: grid;
    gap: var(--spacing-lg);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .propositie {
    background: var(--color-surface-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    padding: clamp(var(--spacing-lg), 3vw, var(--spacing-xl));
  }

  .propositie__nr {
    font-family: var(--font-display);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-default);
  }

  .propositie h3 {
    margin-block-start: var(--spacing-xs);
  }

  .propositie p {
    margin-block-start: var(--spacing-sm);
    color: var(--color-text-secondary);
  }

  @media (min-width: 768px) {
    .proposities {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* --- Werkzaamheden --- */
  .b2b-werk {
    display: grid;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .b2b-werk h2 {
    margin-block-start: var(--spacing-md);
  }

  .b2b-werk__lijst {
    margin: var(--spacing-lg) 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--spacing-sm);
  }

  .b2b-werk__lijst li {
    position: relative;
    padding-inline-start: 28px;
  }

  .b2b-werk__lijst li::before {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 0.45em;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-primary-default) 18%, transparent);
    box-shadow: inset 0 0 0 4px color-mix(in srgb, var(--color-primary-default) 65%, transparent);
  }

  .b2b-werk__note {
    margin-block-start: var(--spacing-lg);
    color: var(--color-text-secondary);
    max-width: 52ch;
  }

  .b2b-werk__media {
    margin: 0;
  }

  .b2b-werk__media :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
  }

  @media (min-width: 900px) {
    .b2b-werk {
      grid-template-columns: 1fr 1fr;
      gap: clamp(var(--spacing-xl), 5vw, var(--spacing-2xl));
    }
  }

  /* --- CTA-band (zelfde patroon als overige pagina's) --- */
  .cta-band {
    position: relative;
    overflow: hidden;
    padding-block: clamp(var(--spacing-section), 14vw, 160px);
    color: var(--color-text-inverse);
  }

  .cta-band__bg {
    position: absolute;
    inset: 0;
  }

  .cta-band__bg :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .cta-band__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cta-band__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgb(24 19 14 / 0.92),
      rgb(24 19 14 / 0.72) 55%,
      rgb(24 19 14 / 0.6)
    );
  }

  .cta-band__inner {
    position: relative;
  }

  .cta-band h2 {
    max-width: 24ch;
  }

  .cta-band__sub {
    margin-block-start: var(--spacing-md);
    color: var(--color-neutral-100);
    max-width: 52ch;
  }

  .cta-band__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md);
    margin-block-start: var(--spacing-lg);
  }

  .cta-band__tel {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-inverse);
  }

  .cta-band__micro {
    margin-block-start: var(--spacing-sm);
    font-size: var(--font-size-sm);
    color: var(--color-neutral-100);
  }
</style>
