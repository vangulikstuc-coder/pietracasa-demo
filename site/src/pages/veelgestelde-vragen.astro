---
import { Picture, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ctaSfeer from '../assets/images/sections/cta-sfeer.jpg';

const ogImage = await getImage({ src: ctaSfeer, width: 1200, format: 'jpg' });

interface Vraag {
  v: string;
  a: string;
  link?: { href: string; label: string };
}

interface Groep {
  id: string;
  titel: string;
  icon: string;
  vragen: Vraag[];
}

// Bezwaren eerst: kosten boven planning, daarna werkgebied en garantie.
const groepen: Groep[] = [
  {
    id: 'kosten',
    titel: 'Kosten en vaste prijs',
    icon: 'document',
    vragen: [
      {
        v: 'Wat kost stucwerk bij Stucq?',
        a: 'Elk project is maatwerk; vaste tarieven publiceren wij niet. Na een vrijblijvende opname op locatie ontvangt u een schriftelijke offerte met vaste prijs. U weet vóór de start exact wat het kost.',
        link: { href: '/offerte-aanvragen/', label: 'Vraag een vrijblijvende offerte aan' },
      },
      {
        v: 'Is de vaste prijs echt de eindprijs?',
        a: 'Ja. De offerteprijs is de eindprijs – geen stelposten of open eindjes. Meerwerk gebeurt alleen na uw schriftelijk akkoord, met de prijs erbij.',
      },
      {
        v: 'Is de offerteaanvraag vrijblijvend?',
        a: 'Ja. De aanvraag en de opname op locatie verplichten u tot niets. U beslist pas na ontvangst van de offerte.',
      },
    ],
  },
  {
    id: 'planning',
    titel: 'Planning en doorlooptijd',
    icon: 'calendar',
    vragen: [
      {
        v: 'Hoe snel krijg ik reactie op mijn aanvraag?',
        a: 'Binnen 48 uur. Wij zijn bereikbaar op werkdagen van 7:00 tot 17:00. Spoed is mogelijk binnen 48 uur.',
      },
      {
        v: 'Hoe lang duurt een project?',
        a: 'Dat verschilt per type werk en oppervlak; standaardtermijnen noemen wij daarom niet. Vóór de start ontvangt u een schriftelijke planning met startdatum en opleverdatum.',
      },
      {
        v: 'Worden deadlines gehaald?',
        a: 'Ja, aantoonbaar. Alle 50+ projecten sinds 2020 zijn op de afgesproken datum en binnen budget opgeleverd.',
        link: { href: '/projecten/', label: 'Bekijk afgeronde projecten' },
      },
      {
        v: 'Wat gebeurt er na mijn aanvraag?',
        a: 'Uw project doorloopt vijf vaste stappen: opname, offerte met vaste prijs, planning, uitvoering en oplevering. Elke stap wordt schriftelijk bevestigd.',
        link: { href: '/werkwijze/', label: 'Lees de volledige werkwijze' },
      },
    ],
  },
  {
    id: 'werkgebied',
    titel: 'Werkgebied en diensten',
    icon: 'pin',
    vragen: [
      {
        v: 'In welke regio werkt Stucq?',
        a: 'In Haarlem, Bloemendaal, Zandvoort en omgeving tot 15 km. Ligt uw project net daarbuiten, bel dan eerst even.',
      },
      {
        v: 'Welk werk voert Stucq uit?',
        a: 'Gevelwerk en buitenafwerking, binnenafwerking en renovatie, en microcement vloeren. Per dienst vraagt u een aparte offerte aan.',
        link: { href: '/diensten/gevelwerk-buitenafwerking/', label: 'Bekijk de dienst gevelwerk' },
      },
      {
        v: 'Werkt Stucq ook voor bouwbedrijven?',
        a: 'Ja. Stucq werkt voor bouwbedrijven, vastgoedprojecten en particuliere huiseigenaren in de regio Haarlem.',
      },
    ],
  },
  {
    id: 'garantie',
    titel: 'Garantie en afspraken',
    icon: 'shield',
    vragen: [
      {
        v: 'Wat ligt schriftelijk vast?',
        a: 'De vaste prijs, de werkomschrijving en de start- en opleverdatum. Meerwerk wordt eerst schriftelijk voorgelegd, met prijs, en gebeurt alleen na uw akkoord.',
      },
      {
        v: 'Met wie heb ik contact tijdens het werk?',
        a: 'Met dezelfde vakman, van eerste offerte tot oplevering. Eén aanspreekpunt, geen doorverwijzingen.',
      },
      {
        v: 'Is Stucq geregistreerd en verzekerd?',
        a: 'Ja, Stucq is KvK-geregistreerd en verzekerd. Keurmerken en branchelidmaatschappen tonen wij zodra ze geverifieerd zijn.',
      },
      {
        v: 'Hoe weet ik dat eerdere opdrachtgevers tevreden zijn?',
        a: 'Stucq scoort 4,8 sterren op Google, op basis van 25+ geverifieerde reviews. Daarnaast ziet u voor-na foto’s van afgeronde projecten in Haarlem en omgeving.',
        link: { href: '/projecten/', label: 'Bekijk de voor-na resultaten' },
      },
    ],
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: groepen.flatMap((groep) =>
    groep.vragen.map((vraag) => ({
      '@type': 'Question',
      name: vraag.v,
      acceptedAnswer: { '@type': 'Answer', text: vraag.a },
    }))
  ),
};

const icons: Record<string, string> = {
  pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>',
  document:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>',
  calendar:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/><path d="m9.5 15.5 2 2 3.5-4"/></svg>',
  shield:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="m9 11.5 2 2 4-4"/></svg>',
  phone:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>',
  mail: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>',
  plus: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>',
};
---

<BaseLayout
  title="Veelgestelde vragen – stucadoor in Haarlem | Stucq"
  description="Antwoord op vragen over vaste prijzen, planning, werkgebied en garantie. Vraag vrijblijvend een offerte aan – reactie binnen 48 uur."
  ogImage={ogImage.src}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} is:inline slot="head" />

  <!-- 1. Pagina-hero (tekstkop: geen eigen faq-beeld beschikbaar) -->
  <section class="page-hero" aria-labelledby="faq-title">
    <div class="container page-hero__inner">
      <p class="eyebrow">Veelgestelde vragen</p>
      <h1 id="faq-title">Antwoord op uw vragen over kosten, planning en werkwijze</h1>
      <p class="page-hero__sub">
        De vaste prijs, de planning en het werkgebied: hieronder leest u per thema hoe Stucq het
        regelt. Staat uw vraag er niet bij, bel ons dan direct.
      </p>
      <div class="page-hero__actions">
        <a href="/offerte-aanvragen/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="tel:0681943404" class="page-hero__tel">Bel voor advies: 06 81 94 34 04</a>
      </div>
      <p class="page-hero__micro">Vrijblijvend – vaste prijs, reactie binnen 48 uur.</p>
    </div>
  </section>

  <!-- 2. FAQ gegroepeerd per thema, bezwaren eerst -->
  <section class="section" aria-labelledby="vragen-title">
    <div class="container faq-grid">
      <header class="faq-intro" data-reveal>
        <p class="eyebrow">Per thema</p>
        <h2 id="vragen-title">De meest gestelde vragen</h2>
        <p class="faq-intro__tekst">
          De antwoorden zijn gebaseerd op vaste afspraken: 50+ projecten in Haarlem en omgeving
          sinds 2020, allemaal op tijd en in budget opgeleverd.
        </p>
        <nav class="faq-themas" aria-label="Vraagthema's">
          <ul role="list">
            {
              groepen.map((groep) => (
                <li>
                  <a href={`#faq-${groep.id}`} class="faq-themas__link">
                    <span class="faq-themas__icon" set:html={icons[groep.icon]} aria-hidden="true" />
                    {groep.titel}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </header>

      <div class="faq-groepen">
        {
          groepen.map((groep) => (
            <section
              id={`faq-${groep.id}`}
              class="faq-groep"
              aria-labelledby={`faq-${groep.id}-title`}
              data-reveal
            >
              <h3 id={`faq-${groep.id}-title`} class="faq-groep__titel">
                <span class="faq-groep__icon" set:html={icons[groep.icon]} aria-hidden="true" />
                {groep.titel}
              </h3>
              <div class="faq-lijst">
                {groep.vragen.map((vraag) => (
                  <details class="faq-item" name={`faq-${groep.id}`}>
                    <summary class="faq-item__summary">
                      <span class="faq-item__vraag">{vraag.v}</span>
                      <span class="faq-item__toggle" set:html={icons.plus} aria-hidden="true" />
                    </summary>
                    <div class="faq-item__antwoord">
                      <p>{vraag.a}</p>
                      {vraag.link && (
                        <a href={vraag.link.href} class="faq-item__link">
                          {vraag.link.label}
                          <span aria-hidden="true">&rarr;</span>
                        </a>
                      )}
                    </div>
                  </details>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 3. Nog een vraag? CTA-band -->
  <section class="cta-band" aria-labelledby="cta-title">
    <div class="cta-band__bg" aria-hidden="true">
      <Picture
        src={ctaSfeer}
        widths={[820, 1280, 1920]}
        sizes="100vw"
        formats={['avif', 'webp']}
        alt=""
        loading="lazy"
        decoding="async"
        data-demo="true"
      />
    </div>
    <div class="container cta-band__inner" data-reveal>
      <h2 id="cta-title">Nog een vraag?</h2>
      <p class="cta-band__sub">
        Bel op werkdagen tussen 7:00 en 17:00 of mail uw vraag – u krijgt binnen 48 uur antwoord.
        Liever meteen duidelijkheid over de kosten, vraag dan een offerte aan.
      </p>
      <div class="cta-band__actions">
        <a href="/offerte-aanvragen/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="tel:0681943404" class="cta-band__contact">
          <span class="cta-band__contact-icon" set:html={icons.phone} aria-hidden="true" />
          06 81 94 34 04
        </a>
        <a href="mailto:info@stucqafbouw.nl" class="cta-band__contact">
          <span class="cta-band__contact-icon" set:html={icons.mail} aria-hidden="true" />
          info@stucqafbouw.nl
        </a>
      </div>
      <p class="cta-band__micro">Vrijblijvend – vaste prijs, reactie binnen 48 uur.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  /* --- 1. Pagina-hero (tekstkop met rustige gloed) --- */
  .page-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(var(--spacing-2xl), 9vw, var(--spacing-section));
    border-bottom: 1px solid var(--color-border-default);
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      80% 120% at 85% 0%,
      color-mix(in srgb, var(--color-primary-default) 7%, transparent),
      transparent 60%
    );
  }

  .page-hero__inner {
    position: relative;
  }

  .page-hero h1 {
    margin-block-start: var(--spacing-md);
    max-width: 24ch;
  }

  .page-hero__sub {
    margin-block-start: var(--spacing-md);
    font-size: clamp(var(--font-size-base), 2.5vw, var(--font-size-md));
    color: var(--color-text-secondary);
    max-width: 54ch;
  }

  .page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md) var(--spacing-lg);
    margin-block-start: var(--spacing-xl);
  }

  .page-hero__actions .btn {
    width: 100%;
  }

  @media (min-width: 640px) {
    .page-hero__actions .btn {
      width: auto;
    }
  }

  .page-hero__tel {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .page-hero__tel:hover {
    color: var(--color-primary-default);
  }

  .page-hero__micro {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  /* --- 2. FAQ-grid met sticky intro --- */
  .faq-grid {
    display: grid;
    gap: var(--spacing-xl);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .faq-grid {
      grid-template-columns: 0.8fr 1.2fr;
      gap: var(--spacing-2xl);
    }

    .faq-intro {
      position: sticky;
      top: calc(64px + var(--spacing-xl));
    }
  }

  .faq-intro h2 {
    margin-block-start: var(--spacing-md);
  }

  .faq-intro__tekst {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
    max-width: 48ch;
  }

  .faq-themas {
    margin-block-start: var(--spacing-xl);
  }

  .faq-themas ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .faq-themas__link {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    min-height: 44px;
    padding-block: var(--spacing-sm);
    border-top: 1px solid var(--color-border-default);
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
  }

  .faq-themas li:last-child .faq-themas__link {
    border-bottom: 1px solid var(--color-border-default);
  }

  .faq-themas__link:hover {
    color: var(--color-primary-default);
  }

  .faq-themas__icon {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
  }

  .faq-themas__icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  /* --- Vraaggroepen + accordion --- */
  .faq-groepen {
    display: flex;
    flex-direction: column;
    gap: clamp(var(--spacing-xl), 6vw, var(--spacing-2xl));
  }

  .faq-groep {
    scroll-margin-top: calc(64px + var(--spacing-lg));
  }

  .faq-groep__titel {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    font-size: var(--font-size-md);
  }

  .faq-groep__icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
  }

  .faq-groep__icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .faq-lijst {
    margin-block-start: var(--spacing-md);
    border-block: 1px solid var(--color-border-default);
  }

  .faq-item + .faq-item {
    border-top: 1px solid var(--color-border-default);
  }

  .faq-item__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    min-height: 44px;
    padding-block: var(--spacing-lg);
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-base);
    color: var(--color-text-primary);
  }

  .faq-item__summary::-webkit-details-marker {
    display: none;
  }

  .faq-item__summary:hover {
    color: var(--color-primary-default);
  }

  .faq-item__summary:focus-visible {
    outline: 3px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  .faq-item__toggle {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-pill);
    color: var(--color-text-secondary);
    transition: transform var(--motion-base) var(--motion-easing);
  }

  .faq-item__toggle :global(svg) {
    width: 16px;
    height: 16px;
  }

  .faq-item[open] .faq-item__toggle {
    transform: rotate(45deg);
    border-color: var(--color-primary-default);
    color: var(--color-primary-default);
  }

  .faq-item__antwoord {
    padding-block-end: var(--spacing-lg);
  }

  .faq-item__antwoord p {
    color: var(--color-text-secondary);
    max-width: 60ch;
  }

  .faq-item__link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    min-height: 44px;
    margin-block-start: var(--spacing-sm);
    color: var(--color-primary-default);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .faq-item__link:hover {
    color: var(--color-primary-hover);
  }

  /* --- 3. CTA-band --- */
  .cta-band {
    position: relative;
    overflow: hidden;
    padding-block: clamp(var(--spacing-section), 14vw, 160px);
    color: var(--color-text-inverse);
  }

  .cta-band__bg {
    position: absolute;
    inset: 0;
  }

  .cta-band__bg :global(picture) {
    position: absolute;
    inset: 0;
    display: block;
  }

  .cta-band__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* AA-contrast: op mobiel loopt de tekst tot de rechterrand — daar blijft de scrim dekkend */
  .cta-band__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      color-mix(in srgb, var(--color-neutral-900) 86%, transparent),
      color-mix(in srgb, var(--color-neutral-900) 72%, transparent)
    );
  }

  @media (min-width: 768px) {
    .cta-band__bg::after {
      background: linear-gradient(
        100deg,
        color-mix(in srgb, var(--color-neutral-900) 86%, transparent),
        color-mix(in srgb, var(--color-neutral-900) 60%, transparent)
      );
    }
  }

  .cta-band__inner {
    position: relative;
    z-index: 1;
  }

  .cta-band__sub {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-md);
    color: var(--color-neutral-100);
    max-width: 50ch;
  }

  .cta-band__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md) var(--spacing-lg);
    margin-block-start: var(--spacing-xl);
  }

  .cta-band__contact {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    min-height: 44px;
    color: var(--color-text-inverse);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .cta-band__contact:hover {
    color: var(--color-neutral-200);
  }

  .cta-band__contact-icon {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid color-mix(in srgb, var(--color-text-inverse) 30%, transparent);
    border-radius: var(--radius-pill);
  }

  .cta-band__contact-icon :global(svg) {
    width: 16px;
    height: 16px;
  }

  .cta-band__micro {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--color-neutral-100);
  }
</style>
