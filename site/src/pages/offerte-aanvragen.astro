<script>
  // Formulier: client-side validatie + fetch-verzending met laad-/succes-/foutstatus.
  // Zonder JS valt het formulier terug op een native POST naar /api/offerte
  // (de Pages Function stuurt dan terug naar #aanvraag-ontvangen / #aanvraag-mislukt).
  type Veld = HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;

  const form = document.querySelector<HTMLFormElement>('[data-offerte-form]');

  if (form) {
    const succes = document.querySelector<HTMLElement>('#aanvraag-ontvangen');
    const alertBox = form.querySelector<HTMLElement>('[data-form-alert]');
    const submitBtn = form.querySelector<HTMLButtonElement>('[data-submit]');
    const submitLabel = form.querySelector<HTMLElement>('[data-submit-label]');

    const velden = Array.from(form.elements).filter(
      (el): el is Veld =>
        (el instanceof HTMLInputElement ||
          el instanceof HTMLSelectElement ||
          el instanceof HTMLTextAreaElement) &&
        el.name !== '' &&
        el.name !== 'faxnummer'
    );

    function foutVoor(el: Veld): string {
      const waarde = el.value.trim();
      if (el.required && waarde === '') return 'Dit veld is verplicht';
      if (waarde === '') return '';
      const min = Number(el.getAttribute('minlength') ?? '0');
      if (min > 0 && waarde.length < min) return `Vul minimaal ${min} tekens in`;
      if (el instanceof HTMLInputElement) {
        if (el.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(waarde))
          return 'Controleer het e-mailadres';
        if (el.type === 'tel' && !/^\+?[\d\s()/-]{8,}$/.test(waarde))
          return 'Controleer het telefoonnummer';
        if (el.name === 'postcode' && !/^\d{4}\s?[A-Za-z]{2}$/.test(waarde))
          return 'Controleer de postcode';
      }
      return '';
    }

    function toonFout(el: Veld, fout: string): void {
      const foutEl = document.getElementById(`${el.id}-fout`);
      el.setAttribute('aria-invalid', String(fout !== ''));
      if (foutEl) {
        foutEl.textContent = fout;
        foutEl.hidden = fout === '';
      }
    }

    function zetBezig(bezig: boolean): void {
      if (!submitBtn || !submitLabel) return;
      submitBtn.setAttribute('aria-busy', String(bezig));
      submitBtn.disabled = bezig;
      submitLabel.textContent = bezig ? 'Versturen...' : 'Offerte aanvragen';
    }

    velden.forEach((el) => {
      el.addEventListener('input', () => toonFout(el, ''));
      el.addEventListener('blur', () => {
        if (el.value.trim() !== '') toonFout(el, foutVoor(el));
      });
    });

    /* --- Tweestaps-wizard (zonder JS: één lang formulier, native POST) --- */
    const stap1 = form.querySelector<HTMLElement>('[data-step="1"]');
    const stap2 = form.querySelector<HTMLElement>('[data-step="2"]');
    const nextBtn = form.querySelector<HTMLButtonElement>('[data-next]');
    const prevBtn = form.querySelector<HTMLButtonElement>('[data-prev]');
    const progress = form.querySelector<HTMLElement>('[data-progress]');
    const progressNr = form.querySelector<HTMLElement>('[data-progress-nr]');
    const progressLabel = form.querySelector<HTMLElement>('[data-progress-label]');

    function toonStap(nr: 1 | 2): void {
      if (!stap1 || !stap2) return;
      stap1.hidden = nr !== 1;
      stap2.hidden = nr !== 2;
      if (progressNr) progressNr.textContent = String(nr);
      if (progressLabel) progressLabel.textContent = nr === 1 ? 'Uw klus' : 'Uw gegevens';
      const focusDoel = nr === 1 ? stap1.querySelector<Veld>('select, input') : stap2.querySelector<Veld>('input');
      focusDoel?.focus();
    }

    if (stap1 && stap2 && nextBtn && prevBtn && progress) {
      stap2.hidden = true;
      nextBtn.hidden = false;
      prevBtn.hidden = false;
      progress.hidden = false;

      nextBtn.addEventListener('click', () => {
        let eersteFout: Veld | null = null;
        velden
          .filter((el) => stap1.contains(el))
          .forEach((el) => {
            const fout = foutVoor(el);
            toonFout(el, fout);
            if (fout !== '' && eersteFout === null) eersteFout = el;
          });
        if (eersteFout !== null) {
          (eersteFout as Veld).focus();
          return;
        }
        toonStap(2);
      });
      prevBtn.addEventListener('click', () => toonStap(1));
    }

    /* --- Werkgebied-check op postcode (4 cijfers volstaan) --- */
    const postcodeVeld = form.querySelector<HTMLInputElement>('#postcode');
    const postcodeStatus = form.querySelector<HTMLElement>('[data-postcode-status]');

    function checkWerkgebied(): void {
      if (!postcodeVeld || !postcodeStatus) return;
      const m = postcodeVeld.value.trim().match(/^(\d{4})/);
      if (!m) {
        postcodeStatus.hidden = true;
        return;
      }
      const cijfers = Number(m[1]);
      const binnen = cijfers >= 2000 && cijfers <= 2129;
      postcodeStatus.textContent = binnen
        ? 'Binnen ons werkgebied — wij plannen binnen 48 uur een opname.'
        : 'Buiten ons standaard werkgebied (15 km rond Haarlem). Vraag gerust aan — wij reageren altijd, maar kunnen niet alles aannemen.';
      postcodeStatus.classList.toggle('postcode-status--ok', binnen);
      postcodeStatus.classList.toggle('postcode-status--warn', !binnen);
      postcodeStatus.hidden = false;
    }
    postcodeVeld?.addEventListener('input', checkWerkgebied);
    postcodeVeld?.addEventListener('blur', checkWerkgebied);

    /* --- Foto-upload: previews + limieten (max 5, samen 10 MB) --- */
    const fotoVeld = form.querySelector<HTMLInputElement>('#fotos');
    const previews = form.querySelector<HTMLUListElement>('[data-previews]');
    const fotoFout = document.getElementById('fotos-fout');

    function toonFotos(): void {
      if (!fotoVeld || !previews) return;
      const bestanden = Array.from(fotoVeld.files ?? []);
      const totaal = bestanden.reduce((som, f) => som + f.size, 0);
      let fout = '';
      if (bestanden.length > 5) fout = 'Maximaal 5 foto\u2019s.';
      else if (totaal > 10 * 1024 * 1024) fout = 'Samen maximaal 10 MB.';
      if (fotoFout) {
        fotoFout.textContent = fout;
        fotoFout.hidden = fout === '';
      }
      if (fout !== '') {
        fotoVeld.value = '';
        previews.hidden = true;
        previews.innerHTML = '';
        return;
      }
      previews.innerHTML = '';
      bestanden.forEach((bestand, idx) => {
        const li = document.createElement('li');
        const img = document.createElement('img');
        img.alt = '';
        img.src = URL.createObjectURL(bestand);
        img.addEventListener('load', () => URL.revokeObjectURL(img.src));
        const weg = document.createElement('button');
        weg.type = 'button';
        weg.className = 'upload-previews__weg';
        weg.setAttribute('aria-label', `Verwijder foto ${idx + 1}`);
        weg.textContent = '\u00d7';
        weg.addEventListener('click', () => {
          const dt = new DataTransfer();
          Array.from(fotoVeld.files ?? [])
            .filter((_, i) => i !== idx)
            .forEach((f) => dt.items.add(f));
          fotoVeld.files = dt.files;
          toonFotos();
        });
        li.append(img, weg);
        previews.append(li);
      });
      previews.hidden = bestanden.length === 0;
    }
    fotoVeld?.addEventListener('change', toonFotos);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (alertBox) alertBox.hidden = true;

      let eersteFout: Veld | null = null;
      velden.forEach((el) => {
        const fout = foutVoor(el);
        toonFout(el, fout);
        if (fout !== '' && eersteFout === null) eersteFout = el;
      });
      if (eersteFout !== null) {
        (eersteFout as Veld).focus();
        return;
      }

      zetBezig(true);
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { accept: 'application/json' },
        });
        if (!res.ok) throw new Error(`status ${res.status}`);
        form.hidden = true;
        if (succes) {
          succes.classList.add('is-visible');
          succes.focus();
        }
      } catch (err) {
        if (alertBox) {
          alertBox.textContent =
            err instanceof TypeError
              ? 'Geen verbinding. Probeer opnieuw.'
              : 'Er ging iets mis. Probeer later opnieuw.';
          alertBox.hidden = false;
        }
      } finally {
        zetBezig(false);
      }
    });
  }
</script>
