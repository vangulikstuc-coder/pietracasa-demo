---
import { Picture, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroHome from '../assets/images/hero/hero-home.jpg';
import galerijGevelVoor from '../assets/images/sections/galerij-gevel-voor.jpg';
import galerijGevelNa from '../assets/images/sections/galerij-gevel-na.jpg';
import galerijBinnenVoor from '../assets/images/sections/galerij-binnen-voor.jpg';
import galerijBinnenNa from '../assets/images/sections/galerij-binnen-na.jpg';

const ogImage = await getImage({ src: heroHome, width: 1200, format: 'jpg' });

const duoWidths = [420, 840];
const duoSizes = '(min-width: 768px) 25vw, 50vw';

const kopGaranties = [
  { icon: 'check', label: 'Vrijblijvend' },
  { icon: 'euro', label: 'Vaste prijs' },
  { icon: 'clock', label: 'Reactie binnen 48 uur' },
];

const asideGaranties = [
  {
    icon: 'pin',
    titel: 'Vrijblijvende afspraak op locatie',
    tekst: 'Wij bekijken het werk eerst bij u. U beslist daarna – zonder verplichtingen.',
  },
  {
    icon: 'document',
    titel: 'Vaste prijs op schrift',
    tekst: 'De offerteprijs is de eindprijs. Meerwerk alleen na uw schriftelijk akkoord.',
  },
  {
    icon: 'clock',
    titel: 'Reactie binnen 48 uur',
    tekst: 'U hoort binnen 48 uur waar u aan toe bent. Bereikbaar ma–vr 7:00–17:00.',
  },
];

const diensten = [
  {
    icon: 'gevel',
    titel: 'Gevelwerk & buitenafwerking',
    belofte: 'Strakke gevels op vaste prijs, binnen de afgesproken bouwtermijn.',
  },
  {
    icon: 'roller',
    titel: 'Binnenafwerking & renovatie',
    belofte: 'Wanden en plafonds strak opgeleverd – klaar voor verf of behang.',
  },
  {
    icon: 'vloer',
    titel: 'Microcement vloeren',
    belofte: 'Naadloze vloeren met een vaste prijsopgave vooraf.',
  },
];

const stappen = [
  {
    nr: '01',
    icon: 'pin',
    titel: 'Opname op locatie',
    tekst:
      'U vraagt een offerte aan via het formulier of telefonisch. Binnen 48 uur plannen wij een opname op locatie.',
  },
  {
    nr: '02',
    icon: 'document',
    titel: 'Offerte met vaste prijs',
    tekst: 'Na de opname ontvangt u de offerte met vaste prijs en werkomschrijving op schrift.',
  },
  {
    nr: '03',
    icon: 'calendar',
    titel: 'Planning op papier',
    tekst: 'Start- en opleverdatum worden vóór de start schriftelijk bevestigd.',
  },
  {
    nr: '04',
    icon: 'roller',
    titel: 'Uitvoering volgens planning',
    tekst: 'Eén vakman als aanspreekpunt. Meerwerk alleen na uw schriftelijk akkoord.',
  },
  {
    nr: '05',
    icon: 'badge',
    titel: 'Oplevering',
    tekst: 'U controleert het resultaat samen met de vakman. Oplevering op de afgesproken datum.',
  },
];

const duos = [
  {
    label: 'Gevelwerk · Haarlem',
    voor: { src: galerijGevelVoor, alt: 'Voor: gevel met gescheurd en verweerd stucwerk' },
    na: { src: galerijGevelNa, alt: 'Na: strak gestuukte, egaal afgewerkte gevel' },
  },
  {
    label: 'Binnenafwerking · regio Haarlem',
    voor: { src: galerijBinnenVoor, alt: 'Voor: woonkamer met beschadigde wanden' },
    na: { src: galerijBinnenNa, alt: 'Na: woonkamer met strak gepleisterde wanden' },
  },
];

const typeWerkOpties = [
  'Gevelwerk & buitenafwerking',
  'Binnenafwerking & renovatie',
  'Microcement vloeren',
  'Meerdere diensten of iets anders',
];

/* Prijsindicaties: marktconforme bandbreedtes (NL, 2025/2026) — geen offerte.
   Bronnen genoteerd in open-questions.md; definitieve prijs altijd vast op schrift. */
const prijsindicaties = [
  { dienst: 'Glad stucwerk (sausklaar)', prijs: '€18 – €22 / m²' },
  { dienst: 'Spachtelputz / sierpleister', prijs: '€18 – €22 / m²' },
  { dienst: 'Latex spuiten (incl. verf)', prijs: '€4 – €9 / m²' },
  { dienst: 'Spackspuitwerk', prijs: '€10 – €14 / m²' },
  { dienst: 'Beton ciré (vloer)', prijs: '€90 – €130 / m²' },
  { dienst: 'Microcement vloeren', prijs: 'vergelijkbaar met beton ciré' },
  { dienst: 'Gevelwerk & buitenafwerking', prijs: 'vaste prijs na opname' },
];

const starPath =
  'M12 2.8l2.85 5.78 6.38.93-4.62 4.5 1.09 6.36L12 17.37l-5.7 3 1.09-6.36-4.62-4.5 6.38-.93L12 2.8z';

const icons: Record<string, string> = {
  star: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="${starPath}"/></svg>`,
  starPartial: `<svg viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="star-partial-grad"><stop offset="0.8" stop-color="currentColor"/><stop offset="0.8" stop-color="transparent"/></linearGradient></defs><path d="${starPath}" fill="url(#star-partial-grad)" stroke="currentColor" stroke-width="1"/></svg>`,
  check:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 12.5l5 5 10-11"/></svg>',
  euro: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.5 7a6.5 6.5 0 1 0 0 10"/><path d="M5 10.5h8M5 13.5h8"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg>',
  phone:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>',
  calendar:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/><path d="m9.5 15.5 2 2 3.5-4"/></svg>',
  document:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>',
  badge:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="9" r="6"/><path d="m9.5 9 1.8 1.8L15 7.2"/><path d="M8.5 13.5 7 22l5-3 5 3-1.5-8.5"/></svg>',
  roller:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="13" height="6" rx="2"/><path d="M16 6h4v4h-8v4"/><path d="M12 14v6"/></svg>',
  gevel:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 21h18"/><path d="M5 21V9l7-5 7 5v12"/><path d="M9 21v-6h6v6"/></svg>',
  vloer:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 13l9 5 9-5"/></svg>',
};
---

<BaseLayout
  title="Offerte aanvragen – stucadoor in Haarlem | Stucq"
  description="Vraag vrijblijvend een offerte aan voor stucwerk in Haarlem. Vaste prijs op schrift, reactie binnen 48 uur. 50+ projecten op tijd en in budget opgeleverd."
  ogImage={ogImage.src}
>
  <!-- 1. Pagina-header met micro-garantie -->
  <section class="page-head" aria-labelledby="offerte-title">
    <div class="container" data-reveal>
      <p class="eyebrow">Offerte</p>
      <h1 id="offerte-title">Offerte aanvragen – vrijblijvend en binnen 48 uur reactie</h1>
      <p class="page-head__intro">
        Stucq werkt uitsluitend met vaste prijsafspraken. U weet voor aanvang exact wat het kost
        en wanneer het klaar is.
      </p>
      <ul class="kop-garanties" role="list">
        {
          kopGaranties.map((item) => (
            <li>
              <span class="kop-garanties__icon" set:html={icons[item.icon]} aria-hidden="true" />
              {item.label}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 2. Bewijs-strip boven formulier -->
  <section class="proof-strip" aria-label="Bewijs in cijfers">
    <div class="container proof-strip__inner">
      <p class="proof-strip__item">
        <span class="proof-strip__star" set:html={icons.star} aria-hidden="true" />
        <strong class="tabular">4,8</strong> op Google · <strong class="tabular">25+</strong>
        geverifieerde reviews
      </p>
      <p class="proof-strip__item">
        <strong class="tabular">50+</strong> projecten in Haarlem en omgeving sinds 2020
      </p>
      <p class="proof-strip__item">Allemaal op tijd en in budget opgeleverd</p>
    </div>
  </section>

  <!-- 3. Formulier met contextuele garantie -->
  <section class="section formulier" aria-labelledby="formulier-title">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Aanvraag</p>
        <h2 id="formulier-title">Binnen 48 uur weet u waar u aan toe bent</h2>
        <p class="section-head__intro">
          Vul het formulier in. Wij nemen binnen 48 uur contact met u op voor een vrijblijvende
          afspraak op locatie. Geen offerte zonder dat u akkoord bent met de aanpak.
        </p>
      </header>

      <div class="offerte-grid">
        <div class="form-card">
          <div class="form-success" id="aanvraag-ontvangen" tabindex="-1" role="status">
            <strong>Bedankt! We nemen contact op.</strong>
            <p>U hoort binnen 48 uur van ons – voor een vrijblijvende afspraak op locatie.</p>
          </div>
          <p class="form-alert" id="aanvraag-mislukt" tabindex="-1">
            Er ging iets mis. Probeer later opnieuw. Of bel
            <a href="tel:0681943404">06 81 94 34 04</a>.
          </p>

          <form
            id="offerte-formulier"
            method="post"
            action="/api/offerte"
            enctype="multipart/form-data"
            novalidate
            data-offerte-form
          >
            <p class="form-hint">Velden met <span class="req">*</span> zijn verplicht.</p>

            <div class="hp" aria-hidden="true">
              <label for="faxnummer">Faxnummer</label>
              <input type="text" id="faxnummer" name="faxnummer" tabindex="-1" autocomplete="off" />
            </div>

            <p class="form-progress" data-progress aria-live="polite" hidden>
              Stap <strong data-progress-nr>1</strong> van 2 &middot; <span data-progress-label>Uw klus</span>
            </p>

            <div class="form-step" data-step="1">
              <div class="form-grid">
                <div class="form-field form-field--vol">
                  <label for="type-werk">
                    Type werk <span class="req" aria-hidden="true">*</span>
                  </label>
                  <select id="type-werk" name="type-werk" required aria-describedby="type-werk-fout">
                    <option value="" selected>Maak een keuze</option>
                    {typeWerkOpties.map((optie) => <option value={optie}>{optie}</option>)}
                  </select>
                  <p class="form-error" id="type-werk-fout" hidden></p>
                </div>

                <div class="form-field form-field--vol">
                  <label for="postcode">Postcode <span class="req" aria-hidden="true">*</span></label>
                  <input
                    type="text"
                    id="postcode"
                    name="postcode"
                    required
                    autocomplete="postal-code"
                    aria-describedby="postcode-fout postcode-status"
                  />
                  <p class="form-error" id="postcode-fout" hidden></p>
                  <p class="postcode-status" id="postcode-status" data-postcode-status hidden></p>
                </div>

                <div class="form-field form-field--vol">
                  <label for="omschrijving">
                    Omschrijving van het werk <span class="req" aria-hidden="true">*</span>
                  </label>
                  <textarea
                    id="omschrijving"
                    name="omschrijving"
                    required
                    minlength="10"
                    rows="5"
                    aria-describedby="omschrijving-fout"></textarea>
                  <p class="form-error" id="omschrijving-fout" hidden></p>
                </div>

                <div class="form-field form-field--vol">
                  <label for="fotos">Foto&rsquo;s van de situatie <span class="optioneel">(optioneel)</span></label>
                  <label class="upload" for="fotos" data-upload>
                    <input
                      type="file"
                      id="fotos"
                      name="fotos"
                      accept="image/*"
                      multiple
                      aria-describedby="fotos-hint fotos-fout"
                    />
                    <span class="upload__tekst">Sleep foto&rsquo;s hierheen of <u>kies bestanden</u></span>
                  </label>
                  <p class="form-hint" id="fotos-hint">Max. 5 foto&rsquo;s, samen tot 10 MB. Foto&rsquo;s helpen ons de vaste prijs nauwkeurig te bepalen.</p>
                  <p class="form-error" id="fotos-fout" hidden></p>
                  <ul class="upload-previews" data-previews role="list" hidden></ul>
                </div>
              </div>

              <div class="form-footer">
                <button type="button" class="btn btn--primary" data-next hidden>
                  Volgende stap
                  <span class="btn__arrow" aria-hidden="true">&rarr;</span>
                </button>
                <p class="micro">Vrijblijvend &ndash; vaste prijs, reactie binnen 48 uur.</p>
              </div>
            </div>

            <div class="form-step" data-step="2">
              <div class="form-grid">
                <div class="form-field">
                  <label for="naam">Naam <span class="req" aria-hidden="true">*</span></label>
                  <input
                    type="text"
                    id="naam"
                    name="naam"
                    required
                    minlength="2"
                    autocomplete="name"
                    aria-describedby="naam-fout"
                  />
                  <p class="form-error" id="naam-fout" hidden></p>
                </div>

                <div class="form-field">
                  <label for="telefoon">
                    Telefoonnummer <span class="req" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="tel"
                    id="telefoon"
                    name="telefoon"
                    required
                    autocomplete="tel"
                    aria-describedby="telefoon-fout"
                  />
                  <p class="form-error" id="telefoon-fout" hidden></p>
                </div>

                <div class="form-field form-field--vol">
                  <label for="email">E-mailadres <span class="req" aria-hidden="true">*</span></label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    aria-describedby="email-fout"
                  />
                  <p class="form-error" id="email-fout" hidden></p>
                </div>
              </div>

              <p class="form-alert" data-form-alert role="alert" hidden></p>

              <div class="form-footer form-footer--split">
                <button type="button" class="btn btn--secondary" data-prev hidden>
                  <span class="btn__arrow btn__arrow--terug" aria-hidden="true">&larr;</span>
                  Terug
                </button>
                <button type="submit" class="btn btn--primary" data-submit>
                  <span data-submit-label>Offerte aanvragen</span>
                  <span class="btn__arrow" aria-hidden="true">&rarr;</span>
                </button>
                <p class="micro">Vrijblijvend &ndash; vaste prijs, reactie binnen 48 uur.</p>
              </div>
            </div>
          </form>
        </div>

        <aside class="garantieblok" aria-label="Onze garanties">
          <h3>Wat u van ons krijgt</h3>
          <ul role="list">
            {
              asideGaranties.map((item) => (
                <li>
                  <span class="garantieblok__icon" set:html={icons[item.icon]} aria-hidden="true" />
                  <div>
                    <strong>{item.titel}</strong>
                    <p>{item.tekst}</p>
                  </div>
                </li>
              ))
            }
          </ul>
          <p class="garantieblok__trust">
            <span class="garantieblok__star" set:html={icons.star} aria-hidden="true" />
            4,8 op Google · 25+ geverifieerde reviews
          </p>
        </aside>
      </div>
    </div>
  </section>

  <!-- 4. Of bel direct -->
  <section class="bel-band" aria-labelledby="bel-title">
    <div class="container bel-band__inner" data-reveal>
      <div>
        <h2 id="bel-title">Liever direct contact?</h2>
        <p class="bel-band__sub">
          Bereikbaar maandag t/m vrijdag 7:00–17:00. Spoed mogelijk binnen 48 uur.
        </p>
      </div>
      <a href="tel:0681943404" class="bel-band__tel tabular">06 81 94 34 04</a>
    </div>
  </section>

  <!-- 5. Waarvoor vraagt u een offerte aan -->
  <section class="section" aria-labelledby="waarvoor-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Diensten</p>
        <h2 id="waarvoor-title">Waarvoor vraagt u een offerte aan?</h2>
        <p class="section-head__intro">
          Voor elk type werk ontvangt u een vaste prijs en een heldere planning vóór aanvang.
          Geen open eindjes.
        </p>
      </header>
      <ul class="dienst-rij" role="list" data-reveal-group>
        {
          diensten.map((dienst) => (
            <li class="dienst-blok">
              <span class="dienst-blok__icon" set:html={icons[dienst.icon]} aria-hidden="true" />
              <h3>{dienst.titel}</h3>
              <p>{dienst.belofte}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 5b. Prijsindicaties -->
  <section class="section section--alt" aria-labelledby="prijzen-title" id="prijzen">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Prijsindicatie</p>
        <h2 id="prijzen-title">Wat kost het ongeveer?</h2>
        <p class="section-head__intro">
          Bandbreedtes zoals ze in de markt gelden, zodat u weet waar u aan toe bent. Uw
          definitieve prijs is altijd een vaste prijs op schrift – na de opname op locatie.
        </p>
      </header>
      <dl class="prijslijst" data-reveal-group>
        {
          prijsindicaties.map((rij) => (
            <div class="prijslijst__rij">
              <dt>{rij.dienst}</dt>
              <dd class="tabular">{rij.prijs}</dd>
            </div>
          ))
        }
      </dl>
      <p class="prijslijst__disclaimer" data-reveal>
        Indicaties inclusief materiaal en arbeid, afhankelijk van ondergrond, oppervlakte en
        afwerkingsniveau. Aan deze indicaties kunnen geen rechten worden ontleend – de vaste
        prijs in uw offerte is bindend.
      </p>
    </div>
  </section>

  <!-- 6. Zo verloopt het traject -->
  <section class="section section--alt" aria-labelledby="traject-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Werkwijze</p>
        <h2 id="traject-title">Zo verloopt het traject</h2>
        <p class="section-head__intro">
          Van eerste contact tot oplevering werkt Stucq volgens vijf vaste stappen. U weet bij
          elke stap waar u aan toe bent en wat de volgende stap is.
        </p>
      </header>
      <ol class="steps" role="list" data-reveal-group>
        {
          stappen.map((stap) => (
            <li class="step">
              <div class="step__top">
                <span class="step__nr tabular" aria-hidden="true">{stap.nr}</span>
                <span class="step__icon" set:html={icons[stap.icon]} aria-hidden="true" />
              </div>
              <h3>{stap.titel}</h3>
              <p>{stap.tekst}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- 7. Bewijs: afgeronde projecten in Haarlem -->
  <section class="section" aria-labelledby="bewijs-title">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="eyebrow">Projectbewijs</p>
        <h2 id="bewijs-title">Afgeronde projecten in Haarlem</h2>
        <p class="section-head__intro">
          Hieronder ziet u een selectie uit 50+ afgeronde projecten in Haarlem en omgeving. Elk
          project is op tijd en in budget opgeleverd – de foto's bewijzen het.
        </p>
      </header>
      <div class="duos" data-reveal-group>
        {
          duos.map((duo) => (
            <figure class="duo">
              <div class="duo__media">
                <div class="duo__half">
                  <Picture
                    src={duo.voor.src}
                    widths={duoWidths}
                    sizes={duoSizes}
                    formats={['avif', 'webp']}
                    alt={duo.voor.alt}
                    loading="lazy"
                    decoding="async"
                    data-demo="true"
                  />
                  <span class="duo__chip">Voor</span>
                </div>
                <div class="duo__half">
                  <Picture
                    src={duo.na.src}
                    widths={duoWidths}
                    sizes={duoSizes}
                    formats={['avif', 'webp']}
                    alt={duo.na.alt}
                    loading="lazy"
                    decoding="async"
                    data-demo="true"
                  />
                  <span class="duo__chip duo__chip--na">Na</span>
                </div>
              </div>
              <figcaption>{duo.label}</figcaption>
            </figure>
          ))
        }
