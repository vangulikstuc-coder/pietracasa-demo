---
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ctaSfeer from '../assets/images/sections/cta-sfeer.jpg';

const ogImage = await getImage({ src: ctaSfeer, width: 1200, format: 'jpg' });

const openingstijden = [
  { dag: 'Maandag', tijd: '7:00–17:00' },
  { dag: 'Dinsdag', tijd: '7:00–17:00' },
  { dag: 'Woensdag', tijd: '7:00–17:00' },
  { dag: 'Donderdag', tijd: '7:00–17:00' },
  { dag: 'Vrijdag', tijd: '7:00–17:00' },
  { dag: 'Zaterdag', tijd: 'Gesloten' },
  { dag: 'Zondag', tijd: 'Gesloten' },
];

const plaatsen = ['Haarlem', 'Bloemendaal', 'Zandvoort', 'Omgeving tot 15 km'];

const starPath =
  'M12 2.8l2.85 5.78 6.38.93-4.62 4.5 1.09 6.36L12 17.37l-5.7 3 1.09-6.36-4.62-4.5 6.38-.93L12 2.8z';

const icons: Record<string, string> = {
  star: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="${starPath}"/></svg>`,
  phone:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  mail: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg>',
  euro: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.5 7a6.5 6.5 0 1 0 0 10"/><path d="M5 10.5h8M5 13.5h8"/></svg>',
  badge:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="9" r="6"/><path d="m9.5 9 1.8 1.8L15 7.2"/><path d="M8.5 13.5 7 22l5-3 5 3-1.5-8.5"/></svg>',
};
---

<BaseLayout
  title="Contact – stucadoor in Haarlem | Stucq"
  description="Neem direct contact op met Stucq in Haarlem. Bel 06 81 94 34 04 of mail uw vraag – reactie binnen 48 uur, vrijblijvend en met vaste prijsafspraak."
  ogImage={ogImage.src}
>
  <!-- 1. Paginaheader – Direct contact -->
  <section class="page-head" aria-labelledby="contact-title">
    <div class="container page-head__inner" data-reveal>
      <div>
        <p class="eyebrow">Contact</p>
        <h1 id="contact-title">Direct contact met Stucq – reactie binnen 48 uur</h1>
        <p class="page-head__intro">
          Bereik Stucq via telefoon of e-mail, ook voor offerteaanvragen. Bereikbaar ma–vr
          7:00–17:00. Spoed is bespreekbaar.
        </p>
      </div>
      <p class="page-head__bel">
        <span class="page-head__bel-label">De kortste weg: bel direct</span>
        <a href="tel:0681943404" class="page-head__tel tabular">06 81 94 34 04</a>
      </p>
    </div>
  </section>

  <!-- 2. Contactmiddelen – Twee paden -->
  <section class="section paden" aria-labelledby="paden-title">
    <div class="container">
      <h2 class="visually-hidden" id="paden-title">Contactmiddelen</h2>
      <div class="paden__duo" data-reveal-group>
        <div class="pad-card">
          <span class="pad-card__icon" set:html={icons.phone} aria-hidden="true" />
          <h3>Bel direct</h3>
          <a href="tel:0681943404" class="pad-card__link tabular">06 81 94 34 04</a>
          <p>Bereikbaar maandag t/m vrijdag, 7:00–17:00. Spoed is bespreekbaar.</p>
        </div>
        <div class="pad-card">
          <span class="pad-card__icon" set:html={icons.mail} aria-hidden="true" />
          <h3>Mail uw vraag</h3>
          <a href="mailto:info@stucqafbouw.nl" class="pad-card__link">info@stucqafbouw.nl</a>
          <p>Buiten kantoortijden? Laat een bericht achter – u ontvangt binnen 48 uur een reactie.</p>
        </div>
      </div>
      <p class="paden__micro" data-reveal>Vrijblijvend – vaste prijs, reactie binnen 48 uur.</p>
    </div>
  </section>

  <!-- 3. Contactformulier – Alternatief pad -->
  <section class="section section--alt" aria-labelledby="formulier-title">
    <div class="container formulier" data-reveal-group>
      <div class="formulier__text">
        <p class="eyebrow">Schriftelijk</p>
        <h2 id="formulier-title">Liever schriftelijk? Stuur uw vraag</h2>
        <p>
          Vul uw naam, telefoonnummer, e-mailadres en een korte omschrijving van het werk in.
          Wij nemen binnen 48 uur contact met u op.
        </p>
        <p>
          Gaat het om een concrete aanvraag? Via de
          <a href="/offerte-aanvragen/">offertepagina</a> vraagt u direct een vaste prijsopgave aan.
        </p>
      </div>

      <div class="form-card">
        <div class="form-success" id="bericht-ontvangen" tabindex="-1" role="status">
          <strong>Bedankt! We nemen contact op.</strong>
          <p>U hoort binnen 48 uur van ons – vrijblijvend.</p>
        </div>
        <p class="form-alert" id="bericht-mislukt" tabindex="-1">
          Er ging iets mis. Probeer later opnieuw. Of bel
          <a href="tel:0681943404">06 81 94 34 04</a>.
        </p>

        <form id="contact-formulier" method="post" action="/api/contact" novalidate data-contact-form>
          <p class="form-hint">Velden met <span class="req">*</span> zijn verplicht.</p>

          <div class="hp" aria-hidden="true">
            <label for="faxnummer">Faxnummer</label>
            <input type="text" id="faxnummer" name="faxnummer" tabindex="-1" autocomplete="off" />
          </div>

          <div class="form-grid">
            <div class="form-field">
              <label for="naam">Naam <span class="req" aria-hidden="true">*</span></label>
              <input
                type="text"
                id="naam"
                name="naam"
                required
                minlength="2"
                autocomplete="name"
                aria-describedby="naam-fout"
              />
              <p class="form-error" id="naam-fout" hidden></p>
            </div>

            <div class="form-field">
              <label for="telefoon">
                Telefoonnummer <span class="req" aria-hidden="true">*</span>
              </label>
              <input
                type="tel"
                id="telefoon"
                name="telefoon"
                required
                autocomplete="tel"
                aria-describedby="telefoon-fout"
              />
              <p class="form-error" id="telefoon-fout" hidden></p>
            </div>

            <div class="form-field form-field--vol">
              <label for="email">E-mailadres <span class="req" aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                aria-describedby="email-fout"
              />
              <p class="form-error" id="email-fout" hidden></p>
            </div>

            <div class="form-field form-field--vol">
              <label for="omschrijving">
                Omschrijving van het werk <span class="req" aria-hidden="true">*</span>
              </label>
              <textarea
                id="omschrijving"
                name="omschrijving"
                required
                minlength="10"
                rows="5"
                aria-describedby="omschrijving-fout"></textarea>
              <p class="form-error" id="omschrijving-fout" hidden></p>
            </div>
          </div>

          <p class="form-alert" data-form-alert role="alert" hidden></p>

          <div class="form-footer">
            <button type="submit" class="btn btn--primary" data-submit>
              <span data-submit-label>Verstuur bericht</span>
              <span class="btn__arrow" aria-hidden="true">&rarr;</span>
            </button>
            <p class="micro">Vrijblijvend – vaste prijs, reactie binnen 48 uur.</p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- 4. Werkgebied – Regio overzicht -->
  <section class="section" aria-labelledby="werkgebied-title">
    <div class="container werkgebied" data-reveal-group>
      <div class="werkgebied__text">
        <p class="eyebrow">Werkgebied</p>
        <h2 id="werkgebied-title">Haarlem, Bloemendaal, Zandvoort en omgeving tot 15 km</h2>
        <p>
          Stucq werkt in Haarlem, Bloemendaal, Zandvoort en omgeving tot 15 kilometer. Buiten dit
          werkgebied worden geen opdrachten aangenomen.
        </p>
        <p>
          Twijfelt u of uw locatie binnen het werkgebied valt? Bel
          <a href="tel:0681943404" class="werkgebied__tel tabular">06 81 94 34 04</a> voor directe
          bevestiging.
        </p>
        <ul class="werkgebied__plaatsen" role="list">
          {plaatsen.map((plaats) => <li>{plaats}</li>)}
        </ul>
      </div>
      <figure class="werkgebied__kaart">
        <svg viewBox="0 0 320 320" role="img" aria-labelledby="kaart-title" class="kaart">
          <title id="kaart-title"
            >Schematische weergave van het werkgebied: 15 kilometer rondom Haarlem, met Bloemendaal
            en Zandvoort</title
          >
          <circle cx="160" cy="160" r="140" class="kaart__ring" />
          <circle cx="160" cy="160" r="90" class="kaart__ring kaart__ring--inner" />
          <line x1="160" y1="160" x2="259" y2="61" class="kaart__radius" />
          <text x="262" y="52" class="kaart__radius-label">15 km</text>
          <g class="kaart__plaats kaart__plaats--center">
            <circle cx="160" cy="160" r="7" />
            <text x="160" y="186">Haarlem</text>
          </g>
          <g class="kaart__plaats">
            <circle cx="120" cy="92" r="5" />
            <text x="120" y="76">Bloemendaal</text>
          </g>
          <g class="kaart__plaats">
            <circle cx="52" cy="196" r="5" />
            <text x="52" y="222">Zandvoort</text>
          </g>
        </svg>
        <figcaption class="kaart__caption">
          Schematische weergave van het werkgebied – geen exacte kaart.
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- 5. Openingstijden & beschikbaarheid -->
  <section class="section section--alt" aria-labelledby="tijden-title">
    <div class="container tijden" data-reveal-group>
      <div class="tijden__text">
        <p class="eyebrow">Beschikbaarheid</p>
        <h2 id="tijden-title">Openingstijden en bereikbaarheid</h2>
        <p>
          Kantooruren: maandag t/m vrijdag, 7:00–17:00. Binnen deze uren neemt Stucq direct op of
          belt dezelfde dag terug.
        </p>
        <p class="tijden__spoed">
          <span class="tijden__spoed-icon" set:html={icons.clock} aria-hidden="true" />
          Spoedvragen buiten kantooruren zijn bespreekbaar. Bel
          <a href="tel:0681943404" class="tabular">06 81 94 34 04</a> en spreek een bericht in.
        </p>
      </div>
      <table class="tijden__tabel">
        <caption class="visually-hidden">Openingstijden per dag</caption>
        <tbody>
          {
            openingstijden.map((rij) => (
              <tr class:list={[{ 'is-dicht': rij.tijd === 'Gesloten' }]}>
                <th scope="row">{rij.dag}</th>
                <td class="tabular">{rij.tijd}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <!-- 6. Vertrouwensband – Bewijs voor het laatste moment -->
  <section class="trust-band" aria-labelledby="trust-title">
    <div class="container">
      <h2 class="visually-hidden" id="trust-title">Bewijs in cijfers</h2>
      <ul class="trust-band__rij" role="list" data-reveal-group>
        <li>
          <span class="trust-band__icon" set:html={icons.star} aria-hidden="true" />
          <div>
            <strong class="tabular">4,8 sterren op Google</strong>
            <p>25+ geverifieerde reviews van opdrachtgevers in de regio.</p>
          </div>
        </li>
        <li>
          <span class="trust-band__icon" set:html={icons.badge} aria-hidden="true" />
          <div>
            <strong class="tabular">50+ afgeronde projecten</strong>
            <p>In Haarlem en omgeving sinds 2020 – op tijd en in budget.</p>
          </div>
        </li>
        <li>
          <span class="trust-band__icon" set:html={icons.euro} aria-hidden="true" />
          <div>
            <strong>Vaste prijs op schrift</strong>
            <p>De offerteprijs is de eindprijs. Meerwerk alleen na uw akkoord.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- 7. Secundaire CTA – Offerte of projecten -->
  <section class="cta-band" aria-labelledby="cta-title">
    <div class="container cta-band__inner" data-reveal>
      <h2 id="cta-title">Voorkeur voor een directe prijsindicatie?</h2>
      <p class="cta-band__sub">
        Vraag een vrijblijvende offerte aan of bekijk eerst afgeronde projecten in Haarlem en
        omgeving.
      </p>
      <div class="cta-band__actions">
        <a href="/offerte-aanvragen/" class="btn btn--primary">
          Offerte aanvragen
          <span class="btn__arrow" aria-hidden="true">&rarr;</span>
        </a>
        <a href="/projecten/" class="btn btn--secondary">Bekijk afgeronde projecten</a>
      </div>
      <p class="cta-band__micro">Vrijblijvend – vaste prijs, reactie binnen 48 uur.</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Gedeeld --- */
  .eyebrow {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .micro {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  /* --- 1. Paginaheader --- */
  .page-head {
    background: var(--color-surface-alt);
    padding-block: clamp(var(--spacing-xl), 6vw, var(--spacing-2xl));
  }

  .page-head__inner {
    display: grid;
    gap: var(--spacing-lg);
  }

  .page-head h1 {
    margin-block-start: var(--spacing-md);
    max-width: 20ch;
  }

  .page-head__intro {
    margin-block-start: var(--spacing-md);
    font-size: clamp(var(--font-size-base), 2.5vw, var(--font-size-md));
    color: var(--color-text-secondary);
    max-width: 48ch;
  }

  .page-head__bel {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .page-head__bel-label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .page-head__tel {
    font-family: var(--font-display);
    font-size: clamp(var(--font-size-xl), 6vw, var(--font-size-display));
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    line-height: var(--line-height-tight);
    color: var(--color-text-primary);
    text-decoration: none;
    padding-block: var(--spacing-sm);
  }

  .page-head__tel:hover {
    color: var(--color-primary-default);
  }

  @media (min-width: 900px) {
    .page-head__inner {
      grid-template-columns: 1.1fr 0.9fr;
      align-items: center;
      gap: var(--spacing-2xl);
    }

    .page-head__bel {
      justify-self: end;
      text-align: right;
    }
  }

  /* --- 2. Contactmiddelen --- */
  .paden__duo {
    display: grid;
    gap: var(--spacing-lg);
  }

  .pad-card {
    background: var(--color-surface-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: clamp(var(--spacing-lg), 4vw, var(--spacing-xl));
  }

  .pad-card__icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary-default) 10%, transparent);
    color: var(--color-primary-default);
  }

  .pad-card__icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .pad-card h3 {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .pad-card__link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    margin-block-start: var(--spacing-xs);
    font-family: var(--font-display);
    font-size: clamp(var(--font-size-md), 3vw, var(--font-size-lg));
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  .pad-card__link:hover {
    color: var(--color-primary-default);
  }

  .pad-card p {
    margin-block-start: var(--spacing-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    max-width: 38ch;
  }

  .paden__micro {
    margin-block-start: var(--spacing-lg);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  @media (min-width: 768px) {
    .paden__duo {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* --- 3. Contactformulier --- */
  .formulier {
    display: grid;
    gap: var(--spacing-xl);
    align-items: start;
  }

  .formulier__text h2 {
    margin-block-start: var(--spacing-md);
  }

  .formulier__text p:not(.eyebrow) {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
    max-width: 48ch;
  }

  .formulier__text a {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .formulier__text a:hover {
    color: var(--color-primary-default);
  }

  .form-card {
    background: var(--color-surface-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: clamp(var(--spacing-lg), 4vw, var(--spacing-xl));
  }

  #contact-formulier {
    scroll-margin-block-start: calc(64px + var(--spacing-lg));
  }

  .form-hint {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-block-end: var(--spacing-lg);
  }

  .req {
    color: var(--color-primary-default);
  }

  /* Honeypot: visueel én voor toetsenbord/screenreader buiten bereik */
  .hp {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
  }

  .form-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .form-field textarea {
    resize: vertical;
  }

  .form-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md) var(--spacing-lg);
    margin-block-start: var(--spacing-lg);
  }

  .form-footer .btn {
    width: 100%;
  }

  .form-success,
  .form-alert {
    display: none;
    border-radius: var(--radius-md);
    padding: var(--spacing-md) var(--spacing-lg);
    margin-block-end: var(--spacing-lg);
    scroll-margin-block-start: calc(64px + var(--spacing-lg));
  }

  .form-success {
    background: var(--color-feedback-success-bg);
    border: 1px solid var(--color-feedback-success);
  }

  .form-success strong {
    display: block;
    margin-block-end: var(--spacing-xs);
  }

  .form-success p {
    font-size: var(--font-size-sm);
  }

  .form-alert {
    background: var(--color-feedback-danger-bg);
    border: 1px solid var(--color-feedback-danger);
    color: var(--color-feedback-danger);
    font-size: var(--font-size-sm);
  }

  .form-alert a {
    color: inherit;
    font-weight: var(--font-weight-semibold);
  }

  .form-success:target,
  .form-success.is-visible,
  .form-alert:target,
  .form-alert[role='alert']:not([hidden]) {
    display: block;
  }

  form[hidden] {
    display: none;
  }

  @media (min-width: 640px) {
    .form-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .form-field--vol {
      grid-column: 1 / -1;
    }

    .form-footer .btn {
      width: auto;
    }
  }

  @media (min-width: 900px) {
    .formulier {
      grid-template-columns: 0.8fr 1.2fr;
      gap: var(--spacing-2xl);
    }
  }

  /* --- 4. Werkgebied --- */
  .werkgebied {
    display: grid;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .werkgebied__text h2 {
    margin-block-start: var(--spacing-md);
  }

  .werkgebied__text p {
    margin-block-start: var(--spacing-md);
    color: var(--color-text-secondary);
    max-width: 54ch;
  }

  .werkgebied__tel {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .werkgebied__tel:hover {
    color: var(--color-primary-default);
  }

  .werkgebied__plaatsen {
