---
const diensten = [
  { href: '/gevelwerk/', label: 'Gevelwerk' },
  { href: '/binnenafwerking/', label: 'Binnenafwerking' },
  { href: '/microcement/', label: 'Microcement vloeren' },
];

const navItems = [
  { href: '/projecten/', label: 'Projecten' },
  { href: '/werkwijze/', label: 'Werkwijze' },
  { href: '/over-stucq/', label: 'Over Stucq' },
  { href: '/contact/', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/?$/, '/');
const isActive = (href: string) => currentPath === href;
const dienstActive = diensten.some((d) => isActive(d.href));
---

<header class="site-header" data-header>
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label="Stucq – naar homepagina">Stucq</a>

    <nav class="site-nav" aria-label="Hoofdnavigatie">
      <ul class="site-nav__list">
        <li class="site-nav__dropdown" data-dropdown>
          <button
            type="button"
            class:list={['site-nav__link', 'site-nav__trigger', { 'is-active': dienstActive }]}
            aria-expanded="false"
            aria-controls="diensten-menu"
            data-dropdown-trigger
          >
            Diensten
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2.5 4.5 6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <ul class="site-nav__menu" id="diensten-menu" data-dropdown-menu>
            {
              diensten.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={['site-nav__menu-link', { 'is-active': isActive(item.href) }]}
                    aria-current={isActive(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </li>
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['site-nav__link', { 'is-active': isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a href="/offerte/" class="btn btn--secondary site-header__cta">Offerte aanvragen</a>

    <button
      type="button"
      class="site-header__toggle"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      data-drawer-toggle
    >
      <span class="visually-hidden">Menu openen</span>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</header>

<div class="drawer-overlay" data-drawer-overlay hidden></div>
<div
  class="drawer"
  id="mobile-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
  data-drawer
  hidden
>
  <div class="drawer__head">
    <span class="drawer__brand">Stucq</span>
    <button type="button" class="drawer__close" data-drawer-close>
      <span class="visually-hidden">Menu sluiten</span>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="m5 5 14 14M19 5 5 19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
    </button>
  </div>
  <nav aria-label="Mobiele navigatie">
    <p class="drawer__group-label" id="drawer-diensten-label">Diensten</p>
    <ul class="drawer__list" aria-labelledby="drawer-diensten-label">
      {
        diensten.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['drawer__link', { 'is-active': isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <ul class="drawer__list">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['drawer__link', { 'is-active': isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href="/faq/" class:list={['drawer__link', { 'is-active': isActive('/faq/') }]}>
          Veelgestelde vragen
        </a>
      </li>
    </ul>
  </nav>
  <div class="drawer__footer">
    <a href="/offerte/" class="btn btn--primary">Offerte aanvragen</a>
    <a href="tel:0681943404" class="drawer__phone">Bel voor advies: 06 81 94 34 04</a>
  </div>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    min-height: 64px;
    display: flex;
    align-items: center;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background-color var(--motion-base) var(--motion-easing),
      border-color var(--motion-base) var(--motion-easing);
  }

  .site-header.is-scrolled {
    background: color-mix(in srgb, var(--color-background-default) 82%, transparent);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border-default);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    min-height: 64px;
  }

  .site-header__brand {
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    text-decoration: none;
    padding-block: 10px;
  }

  .site-header__brand:hover {
    color: var(--color-primary-default);
  }

  .site-nav {
    display: none;
    margin-inline-start: auto;
  }

  .site-nav__list {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    list-style: none;
    padding: 0;
  }

  .site-nav__link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: 10px 16px;
    min-height: 44px;
    border: 0;
    border-radius: var(--radius-sm);
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    cursor: pointer;
    transition:
      color var(--motion-fast) var(--motion-easing),
      background-color var(--motion-fast) var(--motion-easing);
  }

  .site-nav__link:hover {
    color: var(--color-text-primary);
  }

  .site-nav__link.is-active {
    color: var(--color-primary-default);
    background: var(--color-surface-alt);
  }

  .site-nav__dropdown {
    position: relative;
  }

  .site-nav__trigger svg {
    transition: transform var(--motion-fast) var(--motion-easing);
  }

  .site-nav__trigger[aria-expanded='true'] svg {
    transform: rotate(180deg);
  }

  .site-nav__menu {
    position: absolute;
    top: calc(100% + var(--spacing-xs));
    left: 0;
    min-width: 240px;
    padding: var(--spacing-sm);
    list-style: none;
    background: var(--color-surface-default);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity var(--motion-fast) var(--motion-easing),
      transform var(--motion-fast) var(--motion-easing),
      visibility var(--motion-fast);
  }

  .site-nav__dropdown.is-open .site-nav__menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .site-nav__menu-link {
    display: block;
    padding: 10px 14px;
    min-height: 44px;
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
  }

  .site-nav__menu-link:hover {
    color: var(--color-text-primary);
    background: var(--color-surface-alt);
  }

  .site-nav__menu-link.is-active {
    color: var(--color-primary-default);
    background: var(--color-surface-alt);
  }

  .site-header__cta {
    display: none;
  }

  .site-header__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-inline-start: auto;
    border: 0;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-primary);
    cursor: pointer;
  }

  .site-header__toggle:hover {
    background: var(--color-surface-alt);
  }

  /* --- Drawer (buiten de header geplaatst i.v.m. backdrop-filter containing block) --- */
  .drawer-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: var(--color-background-overlay);
    opacity: 0;
    transition: opacity 240ms var(--motion-easing);
  }

  .drawer-overlay.is-open {
    opacity: 1;
  }

  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 61;
    width: min(85vw, 360px);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
    background: var(--color-background-elevated);
    box-shadow: var(--shadow-lg);
    transform: translateX(100%);
    transition: transform 240ms var(--motion-easing);
    overflow-y: auto;
  }

  .drawer.is-open {
    transform: translateX(0);
  }

  .drawer__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .drawer__brand {
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
  }

  .drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-primary);
    cursor: pointer;
  }

  .drawer__close:hover {
    background: var(--color-surface-alt);
  }

  .drawer__group-label {
    margin-block-end: var(--spacing-xs);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .drawer__list {
    list-style: none;
    padding: 0;
    margin-block-end: var(--spacing-md);
    border-bottom: 1px solid var(--color-border-default);
  }

  .drawer__list:last-of-type {
    border-bottom: 0;
  }

  .drawer__link {
    display: block;
    padding: 12px var(--spacing-sm);
    min-height: 44px;
    border-radius: var(--radius-sm);
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
  }

  .drawer__link:hover {
    background: var(--color-surface-alt);
    color: var(--color-text-primary);
  }

  .drawer__link.is-active {
    color: var(--color-primary-default);
    background: var(--color-surface-alt);
  }

  .drawer__footer {
    margin-block-start: auto;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .drawer__footer .btn {
    width: 100%;
  }

  .drawer__phone {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    text-align: center;
    text-decoration: none;
  }

  .drawer__phone:hover {
    color: var(--color-primary-default);
  }

  @media (min-width: 900px) {
    .site-nav {
      display: block;
    }

    .site-header__cta {
      display: inline-flex;
    }

    .site-header__toggle {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .drawer,
    .drawer-overlay,
    .site-nav__menu {
      transition: none;
    }
  }
</style>

<script>
  // Frosted header bij scroll
  const header = document.querySelector<HTMLElement>('[data-header]');
  const onScroll = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 8);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Diensten-dropdown (desktop)
  const dropdown = document.querySelector<HTMLElement>('[data-dropdown]');
  const trigger = document.querySelector<HTMLButtonElement>('[data-dropdown-trigger]');

  function setDropdown(open: boolean): void {
    dropdown?.classList.toggle('is-open', open);
    trigger?.setAttribute('aria-expanded', String(open));
  }

  trigger?.addEventListener('click', () => {
    setDropdown(!dropdown?.classList.contains('is-open'));
  });

  document.addEventListener('click', (e) => {
    if (dropdown && !dropdown.contains(e.target as Node)) setDropdown(false);
  });

  dropdown?.addEventListener('focusout', (e) => {
    if (!dropdown.contains(e.relatedTarget as Node)) setDropdown(false);
  });

  // Mobiel drawer-menu met focus-trap
  const toggle = document.querySelector<HTMLButtonElement>('[data-drawer-toggle]');
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');
  const overlay = document.querySelector<HTMLElement>('[data-drawer-overlay]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-drawer-close]');

  const focusablesSelector =
    'a[href], button:not([disabled]), input, select, textarea, [tabindex]:not([tabindex="-1"])';

  function openDrawer(): void {
    if (!drawer || !overlay) return;
    drawer.hidden = false;
    overlay.hidden = false;
    requestAnimationFrame(() => {
      drawer.classList.add('is-open');
      overlay.classList.add('is-open');
    });
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeDrawer(): void {
    if (!drawer || !overlay) return;
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    window.setTimeout(
      () => {
        drawer.hidden = true;
        overlay.hidden = true;
      },
      reduced ? 0 : 240
    );
    toggle?.focus();
  }

  toggle?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      setDropdown(false);
      if (drawer && !drawer.hidden) closeDrawer();
      return;
    }
    if (e.key !== 'Tab' || !drawer || drawer.hidden) return;
    const focusables = Array.from(drawer.querySelectorAll<HTMLElement>(focusablesSelector));
    if (focusables.length === 0) return;
    const first = focusables[0]!;
    const last = focusables[focusables.length - 1]!;
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
